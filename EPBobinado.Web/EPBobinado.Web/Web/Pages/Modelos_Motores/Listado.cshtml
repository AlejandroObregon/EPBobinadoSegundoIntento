@page
@model Web.Pages.ModeloMotor.ListadoModel
@{
    Layout = "_LayoutUser";
    ViewData["Title"] = "Modelos de Motor";
}

<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">

<div class="mm-page">

    <!-- HEADER -->
    <div class="mm-header">
        <div class="mm-header-left">
            <div class="mm-header-icon">⚙️</div>
            <div>
                <h1 class="mm-title">Modelos de Motor</h1>
                <p class="mm-subtitle">@Model.Modelos.Count modelo(s) en el catálogo</p>
            </div>
        </div>
        <a asp-page="Agregar" class="mm-btn mm-btn-primary">
            <i class="bi bi-plus-lg"></i> Nuevo Modelo
        </a>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="mm-toast mm-toast-success">
            <i class="bi bi-check-circle-fill"></i> @TempData["MensajeExito"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="mm-toast mm-toast-success">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        </div>
    }

    @if (!Model.Modelos.Any())
    {
        <div class="mm-empty">
            <div class="mm-empty-icon">⚙️</div>
            <h3>Catálogo vacío</h3>
            <p>Agrega el primer modelo de motor al catálogo</p>
            <a asp-page="Agregar" class="mm-btn mm-btn-primary">
                <i class="bi bi-plus-lg"></i> Nuevo Modelo
            </a>
        </div>
    }
    else
    {
        <!-- BARRA DE BÚSQUEDA -->
        <div class="mm-toolbar">
            <div class="mm-search-wrap">
                <i class="bi bi-search mm-search-icon"></i>
                <input type="text" id="mm-search" class="mm-search-input"
                       placeholder="Buscar por nombre o especificaciones..." autocomplete="off" />
                <button id="mm-clear" class="mm-search-clear" style="display:none">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <span class="mm-count-badge" id="mm-count">@Model.Modelos.Count modelos</span>
        </div>

        <!-- GRID DE TARJETAS -->
        <div class="mm-grid" id="mm-grid">
            @{
                int idx = 0;
            }
            @foreach (var m in Model.Modelos.OrderBy(x => x.Nombre))
            {
                var hasSpecs = !string.IsNullOrWhiteSpace(m.Especificaciones);
                <div class="mm-card" style="animation-delay:@(idx * 0.05)s"
                     data-nombre="@m.Nombre.ToLower()"
                     data-specs="@(m.Especificaciones?.ToLower() ?? "")">

                    <!-- Indicador numérico -->
                    <div class="mm-card-num">@(idx + 1)</div>

                    <div class="mm-card-body">
                        <div class="mm-card-icon-wrap">
                            <i class="bi bi-gear-wide-connected"></i>
                        </div>
                        <h3 class="mm-card-name">@m.Nombre</h3>

                        @if (hasSpecs)
                        {
                            <p class="mm-card-specs">@m.Especificaciones</p>
                        }
                        else
                        {
                            <p class="mm-card-no-specs">Sin especificaciones registradas</p>
                        }
                    </div>

                    <div class="mm-card-footer">
                        <span class="mm-card-id">#@m.Id</span>
                        <div class="mm-card-actions">
                            <a asp-page="Editar" asp-route-id="@m.Id" class="mm-action mm-action-edit" title="Editar">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <a asp-page="Eliminar" asp-route-id="@m.Id" class="mm-action mm-action-delete" title="Eliminar">
                                <i class="bi bi-trash-fill"></i>
                            </a>
                        </div>
                    </div>
                </div>
                idx++;
            }
        </div>

        <!-- Sin resultados de búsqueda -->
        <div id="mm-no-results" class="mm-no-results" style="display:none">
            <i class="bi bi-search"></i>
            <p>No se encontraron modelos con ese criterio</p>
        </div>
    }
</div>

<style>
    :root {
        --mm-bg: #f0fdf4;
        --mm-surface: #ffffff;
        --mm-border: #d1fae5;
        --mm-green: #10b981;
        --mm-green2: #059669;
        --mm-dark: #064e3b;
        --mm-text: #111827;
        --mm-muted: #6b7280;
        --mm-radius: 14px;
        --mm-shadow: 0 4px 20px rgba(0,0,0,.06);
        --mm-ff-title: 'Barlow Condensed', sans-serif;
        --mm-ff-body: 'Barlow', sans-serif;
    }

    .mm-page {
        font-family: var(--mm-ff-body);
    }

    /* HEADER */
    .mm-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
        gap: 16px;
        flex-wrap: wrap;
    }

    .mm-header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .mm-header-icon {
        font-size: 42px;
        filter: drop-shadow(0 0 10px rgba(16,185,129,.4));
    }

    .mm-title {
        font-family: var(--mm-ff-title);
        font-size: 32px;
        font-weight: 800;
        color: var(--mm-text);
        margin: 0;
        letter-spacing: -.5px;
    }

    .mm-subtitle {
        font-size: 13px;
        color: var(--mm-muted);
        margin: 4px 0 0;
    }

    /* BUTTONS */
    .mm-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 11px 22px;
        border-radius: 10px;
        font-family: var(--mm-ff-body);
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: all .2s ease;
        white-space: nowrap;
    }

    .mm-btn-primary {
        background: linear-gradient(135deg, var(--mm-green), var(--mm-green2));
        color: white;
    }

        .mm-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(16,185,129,.4);
            color: white;
            text-decoration: none;
        }

    .mm-btn-ghost {
        background: var(--mm-surface);
        border: 1.5px solid var(--mm-border);
        color: var(--mm-muted);
    }

        .mm-btn-ghost:hover {
            border-color: var(--mm-green);
            color: var(--mm-green2);
            text-decoration: none;
        }

    .mm-btn-danger {
        background: linear-gradient(135deg,#ef4444,#dc2626);
        color: white;
    }

        .mm-btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(239,68,68,.35);
            color: white;
            text-decoration: none;
        }

    /* TOAST */
    .mm-toast {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 18px;
        border-radius: var(--mm-radius);
        font-size: 14px;
        margin-bottom: 20px;
    }

    .mm-toast-success {
        background: #ecfdf5;
        border: 1px solid #a7f3d0;
        color: #065f46;
    }

    .mm-toast-danger {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    /* TOOLBAR */
    .mm-toolbar {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 22px;
        flex-wrap: wrap;
    }

    .mm-search-wrap {
        position: relative;
        flex: 1;
        min-width: 240px;
    }

    .mm-search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--mm-muted);
        font-size: 14px;
        pointer-events: none;
    }

    .mm-search-input {
        width: 100%;
        padding: 11px 40px 11px 42px;
        border: 1.5px solid var(--mm-border);
        border-radius: 10px;
        font-family: var(--mm-ff-body);
        font-size: 14px;
        color: var(--mm-text);
        background: var(--mm-surface);
        outline: none;
        transition: all .2s ease;
    }

        .mm-search-input:focus {
            border-color: var(--mm-green);
            box-shadow: 0 0 0 3px rgba(16,185,129,.12);
        }

        .mm-search-input::placeholder {
            color: #9ca3af;
        }

    .mm-search-clear {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: var(--mm-muted);
        display: flex;
        align-items: center;
        padding: 2px;
        border-radius: 4px;
        transition: color .15s;
    }

        .mm-search-clear:hover {
            color: var(--mm-text);
        }

    .mm-count-badge {
        font-size: 13px;
        font-weight: 600;
        color: var(--mm-green2);
        background: #ecfdf5;
        border: 1px solid #a7f3d0;
        padding: 7px 14px;
        border-radius: 100px;
        white-space: nowrap;
    }

    /* GRID */
    .mm-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px,1fr));
        gap: 20px;
    }

    /* CARD */
    .mm-card {
        background: var(--mm-surface);
        border-radius: var(--mm-radius);
        border: 1.5px solid var(--mm-border);
        box-shadow: var(--mm-shadow);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        position: relative;
        transition: all .25s ease;
        animation: mmFadeUp .45s ease both;
    }

        .mm-card:hover {
            transform: translateY(-4px);
            border-color: var(--mm-green);
            box-shadow: 0 12px 36px rgba(16,185,129,.15);
        }

    @@keyframes mmFadeUp {
        from {
            opacity: 0;
            transform: translateY(14px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Número de posición en esquina superior derecha */
    .mm-card-num {
        position: absolute;
        top: 14px;
        right: 14px;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: #ecfdf5;
        border: 1.5px solid var(--mm-border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: var(--mm-green2);
        font-family: var(--mm-ff-title);
    }

    .mm-card-body {
        padding: 22px 20px 16px;
        flex: 1;
    }

    .mm-card-icon-wrap {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--mm-green), var(--mm-green2));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: white;
        margin-bottom: 14px;
        box-shadow: 0 4px 12px rgba(16,185,129,.3);
    }

    .mm-card-name {
        font-family: var(--mm-ff-title);
        font-size: 17px;
        font-weight: 700;
        color: var(--mm-text);
        margin: 0 0 10px;
        line-height: 1.3;
        padding-right: 30px; /* espacio para el número */
    }

    .mm-card-specs {
        font-size: 12.5px;
        color: var(--mm-muted);
        line-height: 1.65;
        font-family: 'Courier New', monospace;
        background: #f0fdf4;
        border-radius: 8px;
        padding: 10px 12px;
        border-left: 3px solid var(--mm-green);
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .mm-card-no-specs {
        font-size: 13px;
        color: #d1d5db;
        font-style: italic;
        margin: 0;
    }

    .mm-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 20px;
        border-top: 1px solid var(--mm-border);
        background: #f9fefb;
    }

    .mm-card-id {
        font-size: 12px;
        font-weight: 700;
        color: #9ca3af;
        letter-spacing: .06em;
        font-family: var(--mm-ff-title);
    }

    .mm-card-actions {
        display: flex;
        gap: 6px;
    }

    .mm-action {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        text-decoration: none;
        transition: all .2s ease;
        border: 1.5px solid var(--mm-border);
        background: white;
    }

    .mm-action-edit {
        color: var(--mm-green2);
    }

        .mm-action-edit:hover {
            background: #ecfdf5;
            border-color: var(--mm-green);
            color: var(--mm-dark);
            text-decoration: none;
        }

    .mm-action-delete {
        color: #ef4444;
    }

        .mm-action-delete:hover {
            background: #fee2e2;
            border-color: #ef4444;
            color: #991b1b;
            text-decoration: none;
        }

    /* NO RESULTS */
    .mm-no-results {
        padding: 60px 24px;
        text-align: center;
        color: var(--mm-muted);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        font-size: 30px;
    }

        .mm-no-results p {
            margin: 0;
            font-size: 15px;
        }

    /* EMPTY */
    .mm-empty {
        text-align: center;
        padding: 80px 24px;
        background: var(--mm-surface);
        border-radius: var(--mm-radius);
        border: 1.5px dashed var(--mm-border);
    }

    .mm-empty-icon {
        font-size: 56px;
        display: block;
        margin-bottom: 16px;
    }

    .mm-empty h3 {
        font-family: var(--mm-ff-title);
        font-size: 22px;
        font-weight: 700;
        color: var(--mm-text);
        margin-bottom: 8px;
    }

    .mm-empty p {
        color: var(--mm-muted);
        margin-bottom: 24px;
    }

    /* FORM SHARED */
    .mm-form-wrap {
        max-width: 580px;
    }

    .mm-form-card {
        background: var(--mm-surface);
        border-radius: var(--mm-radius);
        box-shadow: var(--mm-shadow);
        border: 1.5px solid var(--mm-border);
        padding: 36px;
    }

    .mm-form-section-title {
        font-family: var(--mm-ff-title);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--mm-green2);
        margin-bottom: 22px;
        padding-bottom: 10px;
        border-bottom: 1.5px solid var(--mm-border);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .mm-field {
        display: flex;
        flex-direction: column;
        gap: 7px;
        margin-bottom: 22px;
    }

    .mm-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--mm-muted);
        letter-spacing: .04em;
    }

    .mm-input, .mm-textarea {
        padding: 12px 14px;
        border: 1.5px solid var(--mm-border);
        border-radius: 10px;
        font-family: var(--mm-ff-body);
        font-size: 14px;
        color: var(--mm-text);
        background: var(--mm-surface);
        outline: none;
        transition: all .2s ease;
        width: 100%;
    }

        .mm-input:focus, .mm-textarea:focus {
            border-color: var(--mm-green);
            box-shadow: 0 0 0 3px rgba(16,185,129,.12);
        }

        .mm-input::placeholder, .mm-textarea::placeholder {
            color: #9ca3af;
        }

    .mm-textarea {
        resize: vertical;
        font-family: 'Courier New', monospace;
        line-height: 1.6;
    }

    .mm-error {
        font-size: 12px;
        color: #ef4444;
    }

    .mm-form-actions {
        display: flex;
        gap: 12px;
        margin-top: 28px;
        padding-top: 24px;
        border-top: 1.5px solid var(--mm-border);
    }

    /* DELETE */
    .mm-detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(200px,1fr));
        gap: 14px;
        margin-bottom: 28px;
    }

    .mm-detail-full {
        grid-column: 1/-1;
    }

    .mm-detail-item {
        background: #f0fdf4;
        border: 1.5px solid var(--mm-border);
        border-radius: 10px;
        padding: 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .mm-detail-label {
        font-size: 10px;
        font-weight: 700;
        color: var(--mm-muted);
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .mm-detail-value {
        font-size: 15px;
        font-weight: 600;
        color: var(--mm-text);
    }

    .mm-detail-specs {
        font-family: 'Courier New', monospace;
        font-size: 13px;
        font-weight: 400;
        color: var(--mm-muted);
        line-height: 1.6;
    }

    .mm-delete-warning {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px 20px;
        background: #fff7ed;
        border: 1.5px solid #fed7aa;
        border-radius: 10px;
        color: #9a3412;
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 28px;
    }

        .mm-delete-warning i {
            font-size: 22px;
            color: #f97316;
            flex-shrink: 0;
        }

    @@media(max-width:768px) {
        .mm-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .mm-grid {
            grid-template-columns: 1fr;
        }

        .mm-form-card {
            padding: 24px;
        }

        .mm-toolbar {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>

@section Scripts {
    <script>
        (function () {
            const input    = document.getElementById('mm-search');
            const clearBtn = document.getElementById('mm-clear');
            const grid     = document.getElementById('mm-grid');
            const noRes    = document.getElementById('mm-no-results');
            const countBadge = document.getElementById('mm-count');
            const cards    = Array.from(document.querySelectorAll('.mm-card'));
            const total    = cards.length;

            input.addEventListener('input', function () {
                const q = this.value.toLowerCase().trim();
                clearBtn.style.display = q ? 'flex' : 'none';

                let visible = 0;
                cards.forEach((card, i) => {
                    const nombre = card.dataset.nombre || '';
                    const specs  = card.dataset.specs  || '';
                    const show   = !q || nombre.includes(q) || specs.includes(q);
                    card.style.display = show ? '' : 'none';
                    if (show) { card.style.animationDelay = `${visible * 0.04}s`; visible++; }
                });

                noRes.style.display = visible === 0 ? 'flex' : 'none';
                countBadge.textContent = visible === total
                    ? `${total} modelos`
                    : `${visible} de ${total}`;
            });

            clearBtn.addEventListener('click', function () {
                input.value = '';
                input.dispatchEvent(new Event('input'));
                input.focus();
            });
        })();
    </script>
}
