@* /Pages/Shared/_LayoutAdmin.cshtml *@
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - MotoTaller Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        /* ── RESET ── */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --primary-glow: rgba(59,130,246,0.18);
            --accent: #38bdf8;
            --danger: #ef4444;
            --bg-header: #0f172a;
            --bg-nav: #1e293b;
            --bg-nav-hover: #273549;
            --border: rgba(255,255,255,0.07);
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --badge-bg: #1e3a5f;
            --badge-text: #7dd3fc;
            --shadow-header: 0 4px 24px rgba(0,0,0,0.45);
            --bg-body: #f1f5f9;
            --radius: 10px;
            --transition: all 0.2s ease;
        }

        body {
            font-family: 'Nunito', sans-serif;
            background: var(--bg-body);
            color: #1e293b;
            min-height: 100vh;
        }

        /* ════════════════════════════════
                   HEADER WRAPPER
                ════════════════════════════════ */
        .mw-header-wrapper {
            position: sticky;
            top: 0;
            z-index: 200;
            box-shadow: var(--shadow-header);
        }

        /* ── TOP BAR ── */
        .mw-topbar {
            background: var(--bg-header);
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            border-bottom: 1px solid var(--border);
        }

        .mw-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .mw-logo-icon {
            width: 38px;
            height: 38px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 18px;
            box-shadow: 0 0 14px var(--primary-glow);
        }

        .mw-logo-text {
            font-family: 'Rajdhani', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: var(--text-main);
            letter-spacing: 0.5px;
        }

            .mw-logo-text span {
                color: var(--accent);
            }

        .mw-topbar-right {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .mw-user-greeting {
            font-size: 13px;
            color: var(--text-muted);
            margin-right: 8px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .mw-user-greeting strong {
                color: var(--text-main);
                font-weight: 600;
            }

        .mw-role-badge {
            background: var(--badge-bg);
            color: var(--badge-text);
            font-size: 11px;
            font-weight: 700;
            padding: 2px 9px;
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: 0.6px;
        }

        .mw-icon-btn {
            position: relative;
            width: 38px;
            height: 38px;
            border-radius: var(--radius);
            border: none;
            background: rgba(255,255,255,0.05);
            color: var(--text-muted);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            transition: var(--transition);
        }

            .mw-icon-btn:hover {
                background: rgba(255,255,255,0.1);
                color: var(--text-main);
                transform: translateY(-1px);
            }

        .mw-notif-dot {
            position: absolute;
            top: 6px;
            right: 6px;
            width: 8px;
            height: 8px;
            background: var(--danger);
            border-radius: 50%;
            border: 2px solid var(--bg-header);
        }

        .mw-logout-btn {
            display: flex;
            align-items: center;
            gap: 7px;
            padding: 8px 16px;
            border-radius: var(--radius);
            border: none;
            background: rgba(239,68,68,0.12);
            color: #f87171;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            font-family: 'Nunito', sans-serif;
            text-decoration: none;
            transition: var(--transition);
            margin-left: 4px;
        }

            .mw-logout-btn:hover {
                background: var(--danger);
                color: white;
                transform: translateY(-1px);
            }

        /* ── NAV BAR ── */
        .mw-navbar {
            background: var(--bg-nav);
            height: 52px;
            display: flex;
            align-items: center;
            padding: 0 28px;
            gap: 4px;
            border-bottom: 1px solid var(--border);
            overflow-x: auto;
        }

            .mw-navbar::-webkit-scrollbar {
                display: none;
            }

        .mw-nav-item {
            position: relative;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 9px;
            border: none;
            background: transparent;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            font-family: 'Nunito', sans-serif;
            transition: var(--transition);
            white-space: nowrap;
            text-decoration: none;
        }

            .mw-nav-item:hover {
                background: var(--bg-nav-hover);
                color: var(--text-main);
                text-decoration: none;
            }

            .mw-nav-item.active {
                background: var(--primary-glow);
                color: var(--primary);
                border: 1px solid rgba(59,130,246,0.25);
            }

        .mw-nav-badge {
            background: var(--danger);
            color: white;
            font-size: 10px;
            font-weight: 700;
            padding: 1px 6px;
            border-radius: 10px;
        }

        /* ── DROPDOWN ── */
        .mw-dropdown-wrapper {
            position: relative;
        }

        .mw-dropdown-toggle::after {
            content: "\f078";
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            font-size: 10px;
            margin-left: 4px;
            transition: transform 0.2s ease;
            display: inline-block;
        }

        .mw-dropdown-wrapper:hover .mw-dropdown-toggle::after {
            transform: rotate(180deg);
        }

        .mw-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 6px);
            left: 0;
            min-width: 210px;
            background: var(--bg-header);
            border: 1px solid var(--border);
            border-radius: 12px;
            box-shadow: 0 12px 40px rgba(0,0,0,0.5);
            overflow: hidden;
            z-index: 300;
            animation: mwFadeDown 0.2s ease;
        }

        .mw-dropdown-wrapper:hover .mw-dropdown {
            display: block;
        }

        @@keyframes mwFadeDown {
            from {
                opacity: 0;
                transform: translateY(-6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .mw-dropdown-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 18px;
            color: var(--text-muted);
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition);
            border: none;
            background: none;
            width: 100%;
            text-decoration: none;
            font-family: 'Nunito', sans-serif;
            border-bottom: 1px solid var(--border);
        }

            .mw-dropdown-item:last-child {
                border-bottom: none;
            }

            .mw-dropdown-item:hover {
                background: var(--bg-nav-hover);
                color: var(--text-main);
                padding-left: 24px;
                text-decoration: none;
            }

            .mw-dropdown-item i {
                color: var(--primary);
                width: 16px;
                text-align: center;
            }

        /* ── NOTIFICATIONS PANEL ── */
        .mw-notif-wrapper {
            position: relative;
        }

        .mw-notif-panel {
            display: none;
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            width: 340px;
            background: var(--bg-header);
            border: 1px solid var(--border);
            border-radius: 14px;
            box-shadow: 0 12px 40px rgba(0,0,0,0.5);
            overflow: hidden;
            z-index: 400;
            animation: mwFadeDown 0.2s ease;
        }

        .mw-notif-wrapper:hover .mw-notif-panel {
            display: block;
        }

        .mw-notif-header {
            padding: 14px 18px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .mw-notif-header h4 {
                margin: 0;
                font-size: 15px;
                color: var(--text-main);
                font-weight: 700;
            }

        .mw-notif-counter {
            background: var(--primary-glow);
            color: var(--primary);
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 700;
        }

        .mw-notif-list {
            max-height: 300px;
            overflow-y: auto;
        }

        .mw-notif-item {
            display: flex;
            gap: 12px;
            padding: 14px 18px;
            border-bottom: 1px solid var(--border);
            cursor: pointer;
            transition: background 0.15s;
        }

            .mw-notif-item:last-child {
                border-bottom: none;
            }

            .mw-notif-item:hover {
                background: var(--bg-nav-hover);
            }

            .mw-notif-item.unread {
                background: rgba(59,130,246,0.06);
            }

        .mw-notif-icon {
            width: 38px;
            height: 38px;
            border-radius: 9px;
            background: var(--badge-bg);
            color: var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .mw-notif-title {
            margin: 0 0 3px;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-main);
        }

        .mw-notif-time {
            margin: 0;
            font-size: 12px;
            color: var(--text-muted);
        }

        .mw-notif-footer {
            padding: 12px 18px;
            text-align: center;
            background: rgba(255,255,255,0.02);
            border-top: 1px solid var(--border);
        }

            .mw-notif-footer a {
                color: var(--primary);
                font-size: 13px;
                font-weight: 600;
                text-decoration: none;
                transition: color 0.15s;
            }

                .mw-notif-footer a:hover {
                    color: var(--accent);
                }

        /* ── MAIN CONTENT ── */
        .mw-main-content {
            padding: 32px 28px;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 768px) {
            .mw-topbar {
                padding: 0 16px;
                height: 54px;
            }

            .mw-user-greeting {
                display: none;
            }

            .mw-role-badge {
                display: none;
            }

            .mw-navbar {
                padding: 0 12px;
            }

            .mw-logout-btn span {
                display: none;
            }

            .mw-logout-btn {
                padding: 8px 12px;
            }

            .mw-notif-panel {
                width: calc(100vw - 32px);
                right: -8px;
            }

            .mw-main-content {
                padding: 20px 16px;
            }
        }

        @@media (max-width: 480px) {
            .mw-logo-text {
                display: none;
            }

            .mw-nav-item {
                padding: 8px 12px;
                font-size: 13px;
            }
        }
    </style>
</head>
<body>

    @{
        var sessionUsuario = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioNombre") ?? "Admin";
        var sessionRol = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioRol") ?? "admin";
        var rolLabel = sessionRol == "admin" ? "Administrador" :
        sessionRol == "secretaria" ? "Secretaria" : "Usuario";

        var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    }

    <!-- ════════════════════════════════
         HEADER
    ════════════════════════════════ -->
    <div class="mw-header-wrapper">

        <!-- TOP BAR -->
        <div class="mw-topbar">

            <!-- Logo -->
            <a class="mw-logo" asp-page="/Admin/Dashboard">
                <div class="mw-logo-icon">
                    <i class="fas fa-motorcycle"></i>
                </div>
                <span class="mw-logo-text">Moto<span>Taller</span></span>
            </a>

            <!-- Derecha -->
            <div class="mw-topbar-right">

                <!-- Bienvenida -->
                <div class="mw-user-greeting">
                    Bienvenido, <strong>@sessionUsuario</strong>
                    <span class="mw-role-badge">@rolLabel</span>
                </div>

                <!-- Notificaciones (hover) -->
                <div class="mw-notif-wrapper">
                    <button class="mw-icon-btn" title="Notificaciones">
                        <i class="fas fa-bell"></i>
                        <span class="mw-notif-dot"></span>
                    </button>
                    <div class="mw-notif-panel">
                        <div class="mw-notif-header">
                            <h4>Notificaciones</h4>
                            <span class="mw-notif-counter">3 nuevas</span>
                        </div>
                        <div class="mw-notif-list">
                            <div class="mw-notif-item unread">
                                <div class="mw-notif-icon"><i class="fas fa-clipboard-list"></i></div>
                                <div>
                                    <p class="mw-notif-title">Nueva orden creada</p>
                                    <p class="mw-notif-time">Hace 5 minutos</p>
                                </div>
                            </div>
                            <div class="mw-notif-item unread">
                                <div class="mw-notif-icon"><i class="fas fa-user-circle"></i></div>
                                <div>
                                    <p class="mw-notif-title">Nuevo cliente registrado</p>
                                    <p class="mw-notif-time">Hace 1 hora</p>
                                </div>
                            </div>
                            <div class="mw-notif-item">
                                <div class="mw-notif-icon"><i class="fas fa-tools"></i></div>
                                <div>
                                    <p class="mw-notif-title">Servicio completado</p>
                                    <p class="mw-notif-time">Hace 2 horas</p>
                                </div>
                            </div>
                        </div>
                        <div class="mw-notif-footer">
                            <a href="/Admin/Notificaciones">Ver todas las notificaciones</a>
                        </div>
                    </div>
                </div>

                <!-- Salir -->
                <a class="mw-logout-btn" asp-page="/Auth/Login"
                   onclick="sessionStorage.clear(); localStorage.clear();">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Salir</span>
                </a>

            </div>
        </div>

        <!-- NAV BAR -->
        <nav class="mw-navbar">

            <!-- Inicio -->
            <a class="mw-nav-item @(currentPage.Contains("Dashboard") ? "active" : "")"
               asp-page="/Admin/Dashboard">
                <i class="fas fa-home"></i> Inicio
            </a>

            <!-- Motores -->
            <div class="mw-dropdown-wrapper">
                <a class="mw-nav-item mw-dropdown-toggle @(currentPage.Contains("Motor") ? "active" : "")"
                   asp-page="/Admin/Motores/Index">
                    <i class="fas fa-motorcycle"></i> Motores
                </a>
                <div class="mw-dropdown">
                    <a class="mw-dropdown-item" asp-page="/Admin/Motores/Index">
                        <i class="fas fa-motorcycle"></i> Ver todos los motores
                    </a>
                    <a class="mw-dropdown-item" asp-page="/Admin/Motores/Nuevo">
                        <i class="fas fa-plus-circle"></i> Registrar motor
                    </a>
                    <a class="mw-dropdown-item" asp-page="/Admin/Motores/Historial">
                        <i class="fas fa-history"></i> Historial técnico
                    </a>
                </div>
            </div>

            <!-- Órdenes -->
            <div class="mw-dropdown-wrapper">
                <a class="mw-nav-item mw-dropdown-toggle @(currentPage.Contains("Orden") ? "active" : "")"
                   asp-page="/Admin/Ordenes/Index">
                    <i class="fas fa-clipboard-list"></i> Órdenes
                    <span class="mw-nav-badge">3</span>
                </a>
                <div class="mw-dropdown">
                    <a class="mw-dropdown-item" asp-page="/Admin/Ordenes/Activas">
                        <i class="fas fa-spinner"></i> Órdenes activas
                    </a>
                    <a class="mw-dropdown-item" asp-page="/Admin/Ordenes/Nueva">
                        <i class="fas fa-plus-circle"></i> Nueva orden
                    </a>
                    <a class="mw-dropdown-item" asp-page="/Admin/Ordenes/Historial">
                        <i class="fas fa-history"></i> Historial de órdenes
                    </a>
                </div>
            </div>

            <!-- Productos -->
            <div class="mw-dropdown-wrapper">
                <a class="mw-nav-item mw-dropdown-toggle @(currentPage.Contains("Producto") ? "active" : "")"
                   asp-page="/Admin/Productos/Index">
                    <i class="fas fa-box-open"></i> Productos
                </a>
                <div class="mw-dropdown">
                    <a class="mw-dropdown-item" asp-page="/Admin/Productos/Index">
                        <i class="fas fa-box-open"></i> Inventario
                    </a>
                    <a class="mw-dropdown-item" asp-page="/Admin/Productos/Nuevo">
                        <i class="fas fa-plus-circle"></i> Agregar producto
                    </a>
                </div>
            </div>

            <!-- Clientes -->
            <div class="mw-dropdown-wrapper">
                <a class="mw-nav-item mw-dropdown-toggle @(currentPage.Contains("Cliente") ? "active" : "")"
                   asp-page="/Admin/Clientes/Index">
                    <i class="fas fa-users"></i> Clientes
                </a>
                <div class="mw-dropdown">
                    <a class="mw-dropdown-item" asp-page="/Admin/Clientes/Index">
                        <i class="fas fa-users"></i> Ver todos
                    </a>
                    <a class="mw-dropdown-item" asp-page="/Admin/Clientes/Nuevo">
                        <i class="fas fa-user-plus"></i> Nuevo cliente
                    </a>
                </div>
            </div>

            <!-- Configuración -->
            <a class="mw-nav-item @(currentPage.Contains("Configuracion") ? "active" : "")"
               asp-page="/Admin/Configuracion">
                <i class="fas fa-cog"></i> Configuración
            </a>

        </nav>
    </div>

    <!-- ════════════════════════════════
         CONTENIDO
    ════════════════════════════════ -->
    <div class="mw-main-content">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>

