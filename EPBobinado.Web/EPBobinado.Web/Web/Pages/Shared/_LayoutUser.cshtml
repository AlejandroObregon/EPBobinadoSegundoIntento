<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – EP Bobiando</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        /* ── TOKENS ─────────────────────────────── */
        :root {
            --sidebar-width: 260px;
            --sidebar-bg: #1e293b;
            --sidebar-header: #0f172a;
            --sidebar-accent: #3b82f6;
            --sidebar-text: #94a3b8;
            --navbar-height: 70px;
            --primary-color: #667eea;
            --secondary-color: #764ba2;
            --bg-primary: #f8fafc;
            --text-primary: #1e293b;
            --text-secondary: #64748b;
            --border-color: #e2e8f0;
            --shadow-sm: 0 1px 2px rgba(0,0,0,.05);
            --shadow-md: 0 4px 6px -1px rgba(0,0,0,.1);
            --radius-md: 12px;
            --transition: all 0.3s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
        }

        /* ── SIDEBAR ────────────────────────────── */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--sidebar-bg);
            position: fixed;
            left: 0;
            top: 0;
            box-shadow: 2px 0 10px rgba(0,0,0,.15);
            display: flex;
            flex-direction: column;
            z-index: 1000;
            overflow-y: auto;
        }

            .sidebar::-webkit-scrollbar {
                width: 6px;
            }

            .sidebar::-webkit-scrollbar-track {
                background: transparent;
            }

            .sidebar::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,.2);
                border-radius: 3px;
            }

                .sidebar::-webkit-scrollbar-thumb:hover {
                    background: rgba(255,255,255,.3);
                }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid rgba(255,255,255,.1);
            background: var(--sidebar-header);
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .brand-icon {
            font-size: 28px;
            color: var(--sidebar-accent);
        }

        .brand-text {
            font-size: 22px;
            font-weight: 700;
            color: white;
            letter-spacing: -.5px;
        }

        .sidebar-menu {
            list-style: none;
            padding: 16px 12px;
            margin: 0;
            flex: 1;
        }

        .menu-item {
            margin-bottom: 4px;
        }

            .menu-item a {
                display: flex;
                align-items: center;
                gap: 14px;
                padding: 14px 16px;
                color: var(--sidebar-text);
                text-decoration: none;
                border-radius: 10px;
                transition: var(--transition);
                font-weight: 500;
                font-size: 15px;
                position: relative;
            }

                .menu-item a:hover {
                    background: rgba(59,130,246,.1);
                    color: var(--sidebar-accent);
                    transform: translateX(4px);
                }

            .menu-item.active a {
                background: linear-gradient(135deg, #3b82f6, #2563eb);
                color: white;
                box-shadow: 0 4px 12px rgba(59,130,246,.3);
            }

                .menu-item.active a::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 50%;
                    transform: translateY(-50%);
                    width: 4px;
                    height: 70%;
                    background: white;
                    border-radius: 0 4px 4px 0;
                }

        .menu-icon {
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            flex-shrink: 0;
        }

        .menu-label {
            flex: 1;
            white-space: nowrap;
        }

        /* ── NAVBAR ─────────────────────────────── */
        .main-wrapper {
            margin-left: var(--sidebar-width);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .top-navbar {
            height: var(--navbar-height);
            background: white;
            border-bottom: 1px solid var(--border-color);
            box-shadow: var(--shadow-sm);
            position: sticky;
            top: 0;
            z-index: 500;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
        }

        .navbar-left h2 {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0;
        }

        .navbar-left p {
            font-size: 13px;
            color: var(--text-secondary);
            margin: 0;
        }

        .navbar-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 16px;
            flex-shrink: 0;
        }

        .user-name {
            font-weight: 600;
            color: var(--text-primary);
            font-size: 14px;
        }

        .user-role {
            font-size: 12px;
            color: var(--text-secondary);
            display: block;
        }

        .btn-logout {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: none;
            background: var(--bg-primary);
            color: var(--text-secondary);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            transition: var(--transition);
            text-decoration: none;
        }

            .btn-logout:hover {
                background: #fee2e2;
                color: #ef4444;
            }

        /* ── PAGE CONTENT ───────────────────────── */
        .page-content {
            flex: 1;
            padding: 32px 28px;
        }

        /* ── RESPONSIVE ─────────────────────────── */
        @@media (max-width: 768px) {
            .sidebar {
                width: 70px;
            }

            .brand-text, .menu-label {
                display: none;
            }

            .sidebar-brand {
                justify-content: center;
            }

            .menu-item a {
                justify-content: center;
                padding: 14px;
            }

                .menu-item a:hover {
                    transform: none;
                }

            .menu-item.active a::before {
                display: none;
            }

            .main-wrapper {
                margin-left: 70px;
            }

            .top-navbar {
                padding: 0 16px;
            }

            .user-name, .user-role {
                display: none;
            }

            .page-content {
                padding: 20px 16px;
            }
        }
    </style>
</head>
<body>

    <!-- ── SIDEBAR ── -->
    <nav class="sidebar">
        <div class="sidebar-header">
            <a class="sidebar-brand" href="/HomePage/HomePage">
                <i class="bi bi-tools brand-icon"></i>
                <span class="brand-text">Mi Taller</span>
            </a>
        </div>

        @{
            var _rolNivel = Context.Session.GetString("UsuarioNivel") ?? "";
            int.TryParse(_rolNivel, out int _rol);
            bool _esCliente = _rol == 1;
        }

        @if (_esCliente)
        {
            <!-- ── MENÚ CLIENTE ── -->
            <ul class="sidebar-menu">
                <li class="menu-item @(Context.Request.Path == "/ClienteHome" ? "active" : "")">
                    <a href="/ClienteHome">
                        <span class="menu-icon"><i class="bi bi-house-fill"></i></span>
                        <span class="menu-label">Inicio</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Cliente/MisMotores") ? "active" : "")">
                    <a href="/Cliente/MisMotores">
                        <span class="menu-icon"><i class="bi bi-car-front-fill"></i></span>
                        <span class="menu-label">Mis Motores</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Cliente/MisOrdenes") ? "active" : "")">
                    <a href="/Cliente/MisOrdenes">
                        <span class="menu-icon"><i class="bi bi-clipboard-check-fill"></i></span>
                        <span class="menu-label">Mis Órdenes</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Productos/Catalogo") ? "active" : Context.Request.Path == "/Productos/Catalogo" ? "active" : "")">
                    <a href="/Productos/Catalogo">
                        <span class="menu-icon"><i class="bi bi-grid-3x3-gap-fill"></i></span>
                        <span class="menu-label">Catálogo</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Modelos_Motores") ? "active" : "")">
                    <a href="/Modelos_Motores/Listado">
                        <span class="menu-icon"><i class="bi bi-gear-wide-connected"></i></span>
                        <span class="menu-label">Modelos de Motor</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path == "/Cliente/MiHistorial" ? "active" : "")">
                    <a href="/Cliente/MiHistorial">
                        <span class="menu-icon"><i class="bi bi-clock-history"></i></span>
                        <span class="menu-label">Mi Historial</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path == "/Cliente/MiPerfil" ? "active" : "")">
                    <a href="/Cliente/MiPerfil">
                        <span class="menu-icon"><i class="bi bi-person-circle"></i></span>
                        <span class="menu-label">Mi Perfil</span>
                    </a>
                </li>
            </ul>
        }
        else
        {
            <!-- ── MENÚ ADMIN / TÉCNICO ── -->
            <ul class="sidebar-menu">
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Usuarios") ? "active" : "")">
                    <a href="/Usuarios/Listado">
                        <span class="menu-icon"><i class="bi bi-people-fill"></i></span>
                        <span class="menu-label">Usuarios</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Motores") ? "active" : "")">
                    <a href="/Motores/Listado">
                        <span class="menu-icon"><i class="bi bi-car-front-fill"></i></span>
                        <span class="menu-label">Motores</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Modelos_Motores") ? "active" : "")">
                    <a href="/Modelos_Motores/Listado">
                        <span class="menu-icon"><i class="bi bi-gear-wide-connected"></i></span>
                        <span class="menu-label">Modelos de Motor</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Ordenes") ? "active" : "")">
                    <a href="/Ordenes/Listado">
                        <span class="menu-icon"><i class="bi bi-clipboard-check-fill"></i></span>
                        <span class="menu-label">Órdenes</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Productos") ? "active" : "")">
                    <a href="/Productos/Listado">
                        <span class="menu-icon"><i class="bi bi-box-seam-fill"></i></span>
                        <span class="menu-label">Productos</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Diagnosticos_Tecnicos") ? "active" : "")">
                    <a href="/Diagnosticos_Tecnicos/Listado">
                        <span class="menu-icon"><i class="bi bi-tools"></i></span>
                        <span class="menu-label">Diagnósticos</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Diagnosticos_Iniciales") ? "active" : "")">
                    <a href="/Diagnosticos_Iniciales/Listado">
                        <span class="menu-icon"><i class="bi bi-search-heart"></i></span>
                        <span class="menu-label">Diag. Inicial</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Reportes") ? "active" : "")">
                    <a href="/Reportes">
                        <span class="menu-icon"><i class="bi bi-bar-chart-fill"></i></span>
                        <span class="menu-label">Reportes</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Proveedores") ? "active" : "")">
                    <a href="/Proveedores/Listado">
                        <span class="menu-icon"><i class="bi bi-truck"></i></span>
                        <span class="menu-label">Proveedores</span>
                    </a>
                </li>
                <li class="menu-item @(Context.Request.Path.StartsWithSegments("/Respaldos") ? "active" : "")">
                    <a href="/Respaldos/Backup">
                        <span class="menu-icon"><i class="bi bi-shield-fill-check"></i></span>
                        <span class="menu-label">Respaldo de Datos</span>
                    </a>
                </li>
            </ul>
        }
    </nav>

    <!-- ── MAIN WRAPPER ── -->
    <div class="main-wrapper">

        <!-- ── TOP NAVBAR ── -->
        <header class="top-navbar">
            <div class="navbar-left">
                <h2>@(ViewData["Title"]?.ToString() ?? "Mi Taller")</h2>
                <p>@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
            </div>

            <div class="navbar-right">
                <div class="user-info">
                    <div class="user-avatar">
                        @{
                            var nombre = Context.Session.GetString("UsuarioNombre") ?? "U";
                            @nombre[0]
                        }
                    </div>
                    <div>
                        <span class="user-name">@(Context.Session.GetString("UsuarioNombre") ?? "Usuario")</span>
                        <span class="user-role">@(Context.Session.GetString("UsuarioRolNombre") ?? Context.Session.GetString("UsuarioNivel") ?? "")</span>
                    </div>
                </div>
                <a href="../auth/Login" class="btn-logout" title="Cerrar sesión"
                   onclick="return confirm('¿Está seguro de cerrar sesión?')">
                    <i class="bi bi-box-arrow-right"></i>
                </a>
            </div>
        </header>

        <!-- ── PAGE CONTENT ── -->
        <main class="page-content">
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* ── TIMEOUT DE SESIÓN (RQNF-07-001: 20 min de inactividad) ── *@
    @if (Context.Session.GetString("UsuarioId") != null)
    {
        <div id="st-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9999;align-items:center;justify-content:center">
            <div style="background:#fff;border-radius:16px;padding:36px 32px;max-width:400px;width:90%;text-align:center;box-shadow:0 24px 60px rgba(0,0,0,.25)">
                <div style="font-size:48px;margin-bottom:12px">&#x23F0;</div>
                <h3 style="font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:800;color:#0f172a;margin:0 0 8px">Sesión a punto de expirar</h3>
                <p style="font-size:14px;color:#64748b;margin:0 0 6px">Tu sesión cerrará en <strong id="st-countdown" style="color:#f59e0b">2:00</strong> por inactividad.</p>
                <p style="font-size:13px;color:#94a3b8;margin:0 0 24px">Haz clic en Continuar para seguir trabajando.</p>
                <div style="display:flex;gap:12px;justify-content:center">
                    <button onclick="stReset()" style="padding:11px 28px;background:linear-gradient(135deg,#f59e0b,#d97706);color:#0f172a;border:none;border-radius:9px;font-weight:700;font-size:14px;cursor:pointer">
                        Continuar
                    </button>
                    <a href="/Auth/Login" style="padding:11px 22px;background:#f1f5f9;border:1.5px solid #e2e8f0;border-radius:9px;font-weight:600;font-size:14px;color:#64748b;text-decoration:none">
                        Cerrar sesion
                    </a>
                </div>
            </div>
        </div>

        <script>
            (function(){
                const WARN_MS   = 18 * 60 * 1000;
                const LOGOUT_MS = 20 * 60 * 1000;
                const modal     = document.getElementById('st-modal');
                const countdown = document.getElementById('st-countdown');
                let warnTimer, logoutTimer, cdInterval;

                function stReset(){
                    clearTimeout(warnTimer);
                    clearTimeout(logoutTimer);
                    clearInterval(cdInterval);
                    modal.style.display = 'none';
                    warnTimer   = setTimeout(showWarn, WARN_MS);
                    logoutTimer = setTimeout(doLogout, LOGOUT_MS);
                }

                function showWarn(){
                    modal.style.display = 'flex';
                    let secs = 120;
                    countdown.textContent = '2:00';
                    cdInterval = setInterval(function(){
                        secs--;
                        const m = Math.floor(secs / 60);
                        const s = secs % 60;
                        countdown.textContent = m + ':' + String(s).padStart(2, '0');
                        if (secs <= 0) { clearInterval(cdInterval); doLogout(); }
                    }, 1000);
                }

                function doLogout(){ window.location.href = '/Auth/Login'; }

                window.stReset = stReset;

                ['mousemove','keydown','click','scroll','touchstart'].forEach(function(ev){
                    document.addEventListener(ev, function(){
                        if (modal.style.display === 'none') stReset();
                    }, { passive: true });
                });

                stReset();
            })();
        </script>
    }

</body>
</html>
