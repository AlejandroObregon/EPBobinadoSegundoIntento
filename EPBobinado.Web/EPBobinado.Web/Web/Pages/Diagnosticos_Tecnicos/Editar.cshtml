@page "{id:int}"
@model Web.Pages.DiagnosticoTecnico.EditarModel
@{
    Layout = "_LayoutUser";
    ViewData["Title"] = "Editar Diagnóstico Técnico";
}

<div class="dt-page">

    <div class="dt-page-header">
        <div>
            <h2 class="dt-page-title">✏️ Editar Diagnóstico #@ViewData["DiagnosticoId"]</h2>
            <p class="dt-page-sub">Registrado el @ViewData["CreadoEn"]</p>
        </div>
        <a asp-page="Listado" class="dt-btn dt-btn-ghost">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="dt-alert dt-alert-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <ul class="mb-0">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <div class="dt-form-card">
        <form method="post" asp-route-id="@ViewData["DiagnosticoId"]">
            <div asp-validation-summary="ModelOnly" class="dt-alert dt-alert-danger"></div>

            <div class="dt-field">
                <label asp-for="Diagnostico.OrdenId" class="dt-label">Orden de Servicio</label>
                <select asp-for="Diagnostico.OrdenId" class="dt-select">
                    <option value="">— Seleccione una orden —</option>
                    @foreach (var o in Model.Ordenes)
                    {
                        <option value="@o.Id" selected="@(Model.Diagnostico.OrdenId == o.Id)">
                            #@o.Id — @o.Estado
                            @if (o.Motor != null)
                            {
                                <text> — @(o.Motor.NumeroSerie ?? $"Motor #{o.MotorId}")</text>
                            }
                            @if (o.Motor?.Usuario != null)
                            {
                                <text> (@o.Motor.Usuario.Nombre)</text>
                            }
                        </option>
                    }
                </select>
                <span asp-validation-for="Diagnostico.OrdenId" class="dt-error"></span>
            </div>

            <div class="dt-field">
                <label asp-for="Diagnostico.Detalle" class="dt-label">Detalle Técnico</label>
                <textarea asp-for="Diagnostico.Detalle" class="dt-textarea" rows="7"
                          placeholder="Describe detalladamente el diagnóstico técnico..."></textarea>
                <span asp-validation-for="Diagnostico.Detalle" class="dt-error"></span>
            </div>

            <div class="dt-form-actions">
                <button type="submit" class="dt-btn dt-btn-primary">
                    <i class="bi bi-save"></i> Guardar Cambios
                </button>
                <a asp-page="Listado" class="dt-btn dt-btn-ghost">Cancelar</a>
            </div>
        </form>
    </div>
</div>

<style>
    :root {
        --dt-bg: #f1f5f9;
        --dt-surface: #fff;
        --dt-border: #e2e8f0;
        --dt-text: #1e293b;
        --dt-muted: #64748b;
        --dt-radius: 14px;
        --dt-shadow: 0 4px 16px rgba(0,0,0,.07);
        --dt-transition: all .2s ease
    }

    .dt-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        gap: 16px
    }

    .dt-page-title {
        font-size: 26px;
        font-weight: 700;
        color: var(--dt-text);
        margin: 0
    }

    .dt-page-sub {
        font-size: 14px;
        color: var(--dt-muted);
        margin: 2px 0 0
    }

    .dt-alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 14px 18px;
        border-radius: var(--dt-radius);
        font-size: 14px;
        margin-bottom: 20px
    }

    .dt-alert-danger {
        background: #fef2f2;
        border: 1px solid #fca5a5;
        color: #991b1b
    }

    .dt-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: var(--dt-transition);
        white-space: nowrap
    }

    .dt-btn-primary {
        background: linear-gradient(135deg,#3b82f6,#2563eb);
        color: white
    }

        .dt-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(59,130,246,.35);
            color: white;
            text-decoration: none
        }

    .dt-btn-ghost {
        background: var(--dt-surface);
        border: 1px solid var(--dt-border);
        color: var(--dt-muted)
    }

        .dt-btn-ghost:hover {
            background: var(--dt-bg);
            color: var(--dt-text);
            text-decoration: none
        }

    .dt-form-card {
        background: var(--dt-surface);
        border-radius: var(--dt-radius);
        box-shadow: var(--dt-shadow);
        border: 1px solid var(--dt-border);
        padding: 32px
    }

    .dt-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 24px
    }

    .dt-label {
        font-size: 13px;
        font-weight: 600;
        color: #475569
    }

    .dt-select, .dt-textarea {
        padding: 11px 14px;
        border: 1px solid var(--dt-border);
        border-radius: 10px;
        font-size: 14px;
        color: var(--dt-text);
        background: white;
        transition: var(--dt-transition);
        outline: none;
        width: 100%
    }

        .dt-select:focus, .dt-textarea:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,.12)
        }

    .dt-textarea {
        resize: vertical;
        font-family: inherit;
        line-height: 1.6
    }

    .dt-error {
        font-size: 12px;
        color: #ef4444
    }

    .dt-form-actions {
        display: flex;
        gap: 12px;
        margin-top: 8px
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
