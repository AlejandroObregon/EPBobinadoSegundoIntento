@page "{id:int}"
@model Web.Pages.Motores.EditarModel
@{
    ViewData["Title"] = "Editar Motor";
}
@{
    Layout = "_LayoutUser";
}
<h2 class="mb-4">Editar Motor</h2>

<form method="post" asp-route-id="@ViewData["MotorId"]">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Motor.UsuarioId" class="form-label"></label>
        <select asp-for="Motor.UsuarioId" class="form-select">
            <option value="">-- Seleccione un usuario --</option>
            @foreach (var u in Model.Usuarios)
            {
                <option value="@u.Id" selected="@(Model.Motor.UsuarioId == u.Id)">
                    @u.Nombre (@u.Email)
                </option>
            }
        </select>
        <span asp-validation-for="Motor.UsuarioId" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Motor.ModeloId" class="form-label"></label>
        <select asp-for="Motor.ModeloId" class="form-select">
            <option value="">-- Seleccione un modelo --</option>
            @foreach (var m in Model.Modelos)
            {
                <option value="@m.Id" selected="@(Model.Motor.ModeloId == m.Id)">
                    @m.Nombre
                </option>
            }
        </select>
        <span asp-validation-for="Motor.ModeloId" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Motor.NumeroSerie" class="form-label"></label>
        <input asp-for="Motor.NumeroSerie" class="form-control" placeholder="Ej: JYA1234567890" />
        <span asp-validation-for="Motor.NumeroSerie" class="text-danger small"></span>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save"></i> Guardar Cambios
        </button>
        <a asp-page="Listado" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Cancelar
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
