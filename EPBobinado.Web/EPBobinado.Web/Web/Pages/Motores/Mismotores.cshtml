@page "/Cliente/MisMotores"
@model Web.Pages.Cliente.MisMotoresModel
@{
    Layout = "_LayoutUser";
    ViewData["Title"] = "Mis Motos";
}

<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">

<div class="mo-page">

    <!-- HEADER -->
    <div class="mo-header">
        <div class="mo-header-left">
            <div class="mo-header-icon">🏍️</div>
            <div>
                <h1 class="mo-title">MIS MOTOS</h1>
                <p class="mo-subtitle">@Model.Motores.Count moto(s) registrada(s) en tu cuenta</p>
            </div>
        </div>
        <a asp-page="/Motores/Agregar" class="mo-btn mo-btn-primary">
            <i class="bi bi-plus-lg"></i> Registrar Moto
        </a>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="mo-toast mo-toast-success">
            <i class="bi bi-check-circle-fill"></i> @TempData["MensajeExito"]
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div class="mo-toast mo-toast-danger"><i class="bi bi-exclamation-triangle-fill"></i> @e.ErrorMessage</div>
        }
    }

    @if (!Model.Motores.Any())
    {
        <div class="mo-empty">
            <span class="mo-empty-icon">🏍️</span>
            <h3>SIN MOTOS REGISTRADAS</h3>
            <p>Registra tu primera moto para poder crear órdenes de servicio</p>
            <a asp-page="/Motores/Agregar" class="mo-btn mo-btn-primary">
                <i class="bi bi-plus-lg"></i> Registrar mi primera moto
            </a>
        </div>
    }
    else
    {
        <!-- STATS RÁPIDAS -->
        <div class="mm-stats">
            <div class="mm-stat">
                <span class="mm-stat-num">@Model.Motores.Count</span>
                <span class="mm-stat-lbl">Total de motos</span>
            </div>
            <div class="mm-stat">
                <span class="mm-stat-num">@Model.Motores.Select(m => m.Modelo?.Nombre).Distinct().Count(x => x != null)</span>
                <span class="mm-stat-lbl">Modelos distintos</span>
            </div>
            <div class="mm-stat">
                <span class="mm-stat-num">@Model.Motores.OrderByDescending(m => m.CreadoEn).First().CreadoEn.ToString("MMM yyyy")</span>
                <span class="mm-stat-lbl">Último registro</span>
            </div>
        </div>

        <!-- GRID -->
        <div class="mo-grid">
            @{
                int idx = 0;
            }
            @foreach (var m in Model.Motores)
            {
                <div class="mo-card" style="animation-delay:@(idx * 0.07)s">

                    <div class="mo-card-top">
                        <div class="mo-card-num">
                            @(string.IsNullOrWhiteSpace(m.NumeroSerie) ? "SIN SERIE" : m.NumeroSerie.ToUpper())
                        </div>
                        <span class="mo-card-id">#@m.Id</span>
                    </div>

                    <div class="mo-card-body">

                        <div class="mo-card-row">
                            <span class="mo-card-icon"><i class="bi bi-gear-wide-connected"></i></span>
                            <div>
                                <span class="mo-card-label">Modelo</span>
                                <span class="mo-card-value">@(m.Modelo?.Nombre ?? "—")</span>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(m.Modelo?.Especificaciones))
                        {
                            <div class="mo-card-row">
                                <span class="mo-card-icon"><i class="bi bi-card-text"></i></span>
                                <div>
                                    <span class="mo-card-label">Especificaciones</span>
                                    <span class="mo-card-value mo-card-muted">
                                        @(m.Modelo.Especificaciones.Length > 70
                                                                    ? m.Modelo.Especificaciones[..70] + "…"
                                                                    : m.Modelo.Especificaciones)
                                    </span>
                                </div>
                            </div>
                        }

                        <div class="mo-card-row">
                            <span class="mo-card-icon"><i class="bi bi-calendar3"></i></span>
                            <div>
                                <span class="mo-card-label">Registrada el</span>
                                <span class="mo-card-value">@m.CreadoEn.ToString("dd 'de' MMMM, yyyy")</span>
                            </div>
                        </div>

                    </div>

                    <div class="mo-card-footer">
                        <!-- CTA rápido: nueva orden para esta moto -->
                        <a asp-page="/Ordenes/Agregar" class="mo-btn-inline mo-btn-inline-order">
                            <i class="bi bi-clipboard-plus"></i> Nueva orden
                        </a>
                        <div class="mo-card-actions">
                            <a asp-page="/Motores/Editar" asp-route-id="@m.Id" class="mo-action mo-action-edit" title="Editar">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <a asp-page="/Motores/Eliminar" asp-route-id="@m.Id" class="mo-action mo-action-delete" title="Eliminar">
                                <i class="bi bi-trash-fill"></i>
                            </a>
                        </div>
                    </div>

                </div>
                idx++;
            }
        </div>
    }
</div>

<style>
    :root {
        --mo-dark: #0f1923;
        --mo-surface: #17232f;
        --mo-card: #1a2b3c;
        --mo-border: #253444;
        --mo-amber: #f59e0b;
        --mo-amber2: #fbbf24;
        --mo-text: #e2e8f0;
        --mo-muted: #64748b;
        --mo-radius: 12px;
        --mo-ff-display: 'Barlow Condensed', sans-serif;
        --mo-ff-body: 'Barlow', sans-serif;
    }

    .mo-page {
        font-family: var(--mo-ff-body);
    }

    .mo-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        gap: 16px;
        flex-wrap: wrap;
    }

    .mo-header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .mo-header-icon {
        font-size: 44px;
        filter: drop-shadow(0 0 14px rgba(245,158,11,.45));
    }

    .mo-title {
        font-family: var(--mo-ff-display);
        font-size: 42px;
        font-weight: 800;
        letter-spacing: 3px;
        color: var(--mo-text);
        margin: 0;
        line-height: 1;
    }

    .mo-subtitle {
        font-size: 12px;
        color: var(--mo-muted);
        margin: 5px 0 0;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .mo-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 22px;
        border-radius: 8px;
        font-family: var(--mo-ff-display);
        font-size: 15px;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: all .2s;
        white-space: nowrap;
    }

    .mo-btn-primary {
        background: var(--mo-amber);
        color: #0f1923;
    }

        .mo-btn-primary:hover {
            background: var(--mo-amber2);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(245,158,11,.4);
            color: #0f1923;
            text-decoration: none;
        }

    .mo-toast {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 20px;
        border-radius: var(--mo-radius);
        font-size: 14px;
        margin-bottom: 20px;
    }

    .mo-toast-success {
        background: rgba(16,185,129,.1);
        border: 1px solid rgba(16,185,129,.3);
        color: #6ee7b7;
    }

    .mo-toast-danger {
        background: rgba(239,68,68,.1);
        border: 1px solid rgba(239,68,68,.3);
        color: #fca5a5;
    }

    /* STATS */
    .mm-stats {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 16px;
        margin-bottom: 28px;
    }

    .mm-stat {
        background: var(--mo-card);
        border: 1px solid var(--mo-border);
        border-radius: 12px;
        padding: 18px 22px;
        position: relative;
        overflow: hidden;
    }

        .mm-stat::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: var(--mo-amber);
            border-radius: 12px 0 0 12px;
        }

    .mm-stat-num {
        display: block;
        font-family: var(--mo-ff-display);
        font-size: 30px;
        font-weight: 800;
        color: var(--mo-amber);
        line-height: 1.1;
    }

    .mm-stat-lbl {
        display: block;
        font-size: 11px;
        color: var(--mo-muted);
        text-transform: uppercase;
        letter-spacing: .07em;
        margin-top: 3px;
    }

    /* GRID / CARD */
    .mo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px,1fr));
        gap: 20px;
    }

    .mo-card {
        background: var(--mo-card);
        border-radius: var(--mo-radius);
        border: 1px solid var(--mo-border);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: all .25s;
        animation: moSlideUp .5s ease both;
        position: relative;
    }

        .mo-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--mo-amber), transparent);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform .3s;
        }

        .mo-card:hover {
            border-color: rgba(245,158,11,.4);
            transform: translateY(-4px);
            box-shadow: 0 20px 48px rgba(0,0,0,.5), 0 0 0 1px rgba(245,158,11,.08);
        }

            .mo-card:hover::after {
                transform: scaleX(1);
            }

    @@keyframes moSlideUp {
        from {
            opacity: 0;
            transform: translateY(18px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    .mo-card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 20px 14px;
        border-bottom: 1px solid var(--mo-border);
        background: rgba(245,158,11,.03);
    }

    .mo-card-num {
        font-family: var(--mo-ff-display);
        font-size: 20px;
        font-weight: 800;
        letter-spacing: 1.5px;
        color: var(--mo-amber);
    }

    .mo-card-id {
        font-size: 11px;
        font-weight: 700;
        color: var(--mo-muted);
        letter-spacing: .1em;
        background: var(--mo-surface);
        padding: 3px 10px;
        border-radius: 100px;
        border: 1px solid var(--mo-border);
    }

    .mo-card-body {
        padding: 16px 20px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 11px;
    }

    .mo-card-row {
        display: flex;
        align-items: flex-start;
        gap: 11px;
    }

    .mo-card-icon {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        flex-shrink: 0;
        background: var(--mo-surface);
        border: 1px solid var(--mo-border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        color: var(--mo-amber);
        margin-top: 1px;
    }

    .mo-card-label {
        display: block;
        font-size: 10px;
        font-weight: 700;
        color: var(--mo-muted);
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-bottom: 2px;
    }

    .mo-card-value {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: var(--mo-text);
    }

    .mo-card-muted {
        font-size: 13px;
        font-weight: 400;
        color: #94a3b8;
    }

    .mo-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 20px;
        border-top: 1px solid var(--mo-border);
        background: rgba(0,0,0,.18);
        gap: 8px;
    }

    .mo-btn-inline {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 13px;
        border-radius: 7px;
        font-size: 12px;
        font-weight: 700;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: all .2s;
        font-family: var(--mo-ff-display);
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .mo-btn-inline-order {
        background: rgba(59,130,246,.15);
        color: #93c5fd;
        border: 1px solid rgba(59,130,246,.25);
    }

        .mo-btn-inline-order:hover {
            background: rgba(59,130,246,.25);
            color: #bfdbfe;
            text-decoration: none;
        }

    .mo-card-actions {
        display: flex;
        gap: 6px;
    }

    .mo-action {
        width: 32px;
        height: 32px;
        border-radius: 7px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        text-decoration: none;
        transition: all .2s;
        border: 1px solid var(--mo-border);
        background: var(--mo-surface);
    }

    .mo-action-edit {
        color: var(--mo-amber);
    }

        .mo-action-edit:hover {
            background: rgba(245,158,11,.15);
            border-color: var(--mo-amber);
            color: var(--mo-amber2);
            text-decoration: none;
        }

    .mo-action-delete {
        color: #ef4444;
    }

        .mo-action-delete:hover {
            background: rgba(239,68,68,.15);
            border-color: #ef4444;
            color: #fca5a5;
            text-decoration: none;
        }

    .mo-empty {
        text-align: center;
        padding: 90px 24px;
        background: var(--mo-card);
        border-radius: var(--mo-radius);
        border: 1px dashed var(--mo-border);
    }

    .mo-empty-icon {
        font-size: 60px;
        display: block;
        margin-bottom: 16px;
    }

    .mo-empty h3 {
        font-family: var(--mo-ff-display);
        font-size: 24px;
        font-weight: 800;
        color: var(--mo-text);
        letter-spacing: 2px;
        margin-bottom: 8px;
    }

    .mo-empty p {
        color: var(--mo-muted);
        margin-bottom: 24px;
    }

    @@media(max-width:900px) {
        .mm-stats {
            grid-template-columns: 1fr 1fr
        }
    }

    @@media(max-width:600px) {
        .mo-header {
            flex-direction: column;
            align-items: flex-start
        }

        .mo-title {
            font-size: 32px
        }

        .mo-grid {
            grid-template-columns: 1fr
        }

        .mm-stats {
            grid-template-columns: 1fr
        }
    }
</style>
