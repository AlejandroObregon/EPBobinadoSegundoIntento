@page
@model Web.Pages.Usuarios.AgregarModel
@{
    ViewData["Title"] = "Agregar Usuario";
}
@{
    Layout = "_LayoutUser";
}
<h2 class="mb-4">Agregar Usuario</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <ul class="mb-0">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form method="post">

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Usuario.Nombre" class="form-label"></label>
            <input asp-for="Usuario.Nombre" class="form-control" placeholder="Nombre completo" />
            <span asp-validation-for="Usuario.Nombre" class="text-danger small"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Usuario.Cedula" class="form-label"></label>
            <input asp-for="Usuario.Cedula" class="form-control" placeholder="Ej: 1-1234-5678" />
            <span asp-validation-for="Usuario.Cedula" class="text-danger small"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Usuario.Email" class="form-label"></label>
            <input asp-for="Usuario.Email" class="form-control" type="email" placeholder="correo@ejemplo.com" />
            <span asp-validation-for="Usuario.Email" class="text-danger small"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Usuario.Telefono" class="form-label"></label>
            <input asp-for="Usuario.Telefono" class="form-control" placeholder="Ej: 8888-8888" />
            <span asp-validation-for="Usuario.Telefono" class="text-danger small"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Usuario.PasswordHash" class="form-label"></label>
            <input asp-for="Usuario.PasswordHash" class="form-control" type="password" placeholder="Mínimo 6 caracteres" />
            <span asp-validation-for="Usuario.PasswordHash" class="text-danger small"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Usuario.RolId" class="form-label"></label>
            <select asp-for="Usuario.RolId" class="form-select">
                <option value="">-- Seleccione un rol --</option>
                <option value="1">Administrador</option>
                <option value="2">Cliente</option>
                <option value="3">Técnico</option>
            </select>
            <span asp-validation-for="Usuario.RolId" class="text-danger small"></span>
        </div>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="Usuario.Activo" class="form-check-input" type="checkbox" />
        <label asp-for="Usuario.Activo" class="form-check-label"></label>
        <span asp-validation-for="Usuario.Activo" class="text-danger small d-block"></span>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save"></i> Guardar
        </button>
        <a asp-page="Listado" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Cancelar
        </a>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
