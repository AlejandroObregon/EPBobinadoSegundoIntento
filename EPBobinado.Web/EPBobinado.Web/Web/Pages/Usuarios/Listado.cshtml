@page
@model Web.Pages.Usuarios.ListadoModel
@{
    Layout = "_LayoutUser";
    ViewData["Title"] = "Usuarios";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="us-page">

    <!-- HEADER -->
    <div class="us-header">
        <div>
            <h1 class="us-title">Usuarios</h1>
            <p class="us-subtitle">@Model.Usuarios.Count usuario(s) registrado(s)</p>
        </div>
        <a asp-page="Agregar" class="us-btn us-btn-primary">
            <i class="bi bi-person-plus-fill"></i> Nuevo Usuario
        </a>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="us-toast us-toast-success">
            <i class="bi bi-check-circle-fill"></i> @TempData["MensajeExito"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="us-toast us-toast-success">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        </div>
    }

    @if (!Model.Usuarios.Any())
    {
        <div class="us-empty">
            <div class="us-empty-icon">👥</div>
            <h3>Sin usuarios registrados</h3>
            <p>Crea el primer usuario del sistema</p>
            <a asp-page="Agregar" class="us-btn us-btn-primary">
                <i class="bi bi-person-plus-fill"></i> Nuevo Usuario
            </a>
        </div>
    }
    else
    {
        <!-- BARRA DE BÚSQUEDA + FILTROS -->
        <div class="us-toolbar">
            <div class="us-search-wrap">
                <i class="bi bi-search us-search-icon"></i>
                <input type="text" id="us-search" class="us-search-input"
                       placeholder="Buscar por nombre, cédula, correo o rol..." autocomplete="off" />
                <button id="us-search-clear" class="us-search-clear" style="display:none" title="Limpiar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="us-filter-chips">
                <button class="us-chip us-chip-active" data-rol="">Todos</button>
                <button class="us-chip" data-rol="1">Administrador</button>
                <button class="us-chip" data-rol="2">Cliente</button>
                <button class="us-chip" data-rol="3">Técnico</button>
            </div>
        </div>

        <!-- CONTADOR DE RESULTADOS -->
        <p class="us-results-count" id="us-results-count"></p>

        <!-- TABLA -->
        <div class="us-table-card">
            <table class="us-table" id="us-table">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Cédula</th>
                        <th>Teléfono</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Registro</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="us-tbody">
                    @foreach (var u in Model.Usuarios.OrderBy(x => x.Nombre))
                    {
                        var rolSlug = u.RolId == 2 ? "admin" : u.RolId == 1 ? "cliente" : "tecnico";
                        var rolLabel = u.RolId == 2 ? "Administrador" : u.RolId == 1 ? "Cliente" : "Técnico";
                        var initial = string.IsNullOrWhiteSpace(u.Nombre) ? "?" : u.Nombre[0].ToString().ToUpper();

                        <tr class="us-row"
                            data-nombre="@u.Nombre.ToLower()"
                            data-cedula="@(u.Cedula?.ToLower() ?? "")"
                            data-email="@u.Email.ToLower()"
                            data-rol="@u.RolId"
                            data-rol-label="@rolLabel.ToLower()">

                            <td>
                                <div class="us-user-cell">
                                    <div class="us-avatar us-avatar-@rolSlug">@initial</div>
                                    <div>
                                        <span class="us-user-name">@u.Nombre</span>
                                        <span class="us-user-email">@u.Email</span>
                                    </div>
                                </div>
                            </td>
                            <td class="us-td-mono">@(string.IsNullOrWhiteSpace(u.Cedula) ? "—" : u.Cedula)</td>
                            <td class="us-td-mono">@(string.IsNullOrWhiteSpace(u.Telefono) ? "—" : u.Telefono)</td>
                            <td>
                                <span class="us-rol-badge us-rol-@rolSlug">@rolLabel</span>
                            </td>
                            <td>
                                @if (u.Activo)
                                {
                                    <span class="us-status us-status-active">
                                        <span class="us-status-dot"></span> Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="us-status us-status-inactive">
                                        <span class="us-status-dot"></span> Inactivo
                                    </span>
                                }
                            </td>
                            <td class="us-td-date">@u.CreadoEn.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="us-actions">
                                    <a asp-page="Editar" asp-route-id="@u.Id" class="us-action us-action-edit" title="Editar">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <a asp-page="Eliminar" asp-route-id="@u.Id" class="us-action us-action-delete" title="Eliminar">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Sin resultados -->
            <div id="us-no-results" class="us-no-results" style="display:none">
                <i class="bi bi-search" style="font-size:32px;color:#cbd5e1"></i>
                <p>No se encontraron usuarios con ese criterio</p>
            </div>
        </div>
    }
</div>

<style>
    :root {
        --us-bg: #f8fafc;
        --us-surface: #ffffff;
        --us-border: #e2e8f0;
        --us-text: #0f172a;
        --us-muted: #64748b;
        --us-radius: 14px;
        --us-shadow: 0 4px 24px rgba(0,0,0,.06);
        --us-ff: 'DM Sans', sans-serif;
        --us-admin: #ef4444;
        --us-cliente: #3b82f6;
        --us-tecnico: #f59e0b;
    }

    .us-page {
        font-family: var(--us-ff);
    }

    /* HEADER */
    .us-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 28px;
        gap: 16px;
        flex-wrap: wrap;
    }

    .us-title {
        font-size: 32px;
        font-weight: 700;
        color: var(--us-text);
        margin: 0;
        letter-spacing: -.5px;
    }

    .us-subtitle {
        font-size: 14px;
        color: var(--us-muted);
        margin: 4px 0 0;
    }

    /* BUTTONS */
    .us-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 11px 22px;
        border-radius: 10px;
        font-family: var(--us-ff);
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: all .2s ease;
        white-space: nowrap;
    }

    .us-btn-primary {
        background: linear-gradient(135deg,#6366f1,#4f46e5);
        color: white;
    }

        .us-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(99,102,241,.4);
            color: white;
            text-decoration: none;
        }

    .us-btn-ghost {
        background: var(--us-surface);
        border: 1px solid var(--us-border);
        color: var(--us-muted);
    }

        .us-btn-ghost:hover {
            color: var(--us-text);
            border-color: #94a3b8;
            text-decoration: none;
        }

    .us-btn-danger {
        background: linear-gradient(135deg,#ef4444,#dc2626);
        color: white;
    }

        .us-btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(239,68,68,.35);
            color: white;
            text-decoration: none;
        }

    /* TOAST */
    .us-toast {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 18px;
        border-radius: var(--us-radius);
        font-size: 14px;
        margin-bottom: 20px;
    }

    .us-toast-success {
        background: #ecfdf5;
        border: 1px solid #a7f3d0;
        color: #065f46;
    }

    .us-toast-danger {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    /* TOOLBAR */
    .us-toolbar {
        display: flex;
        gap: 14px;
        margin-bottom: 16px;
        flex-wrap: wrap;
        align-items: center;
    }

    .us-search-wrap {
        position: relative;
        flex: 1;
        min-width: 260px;
    }

    .us-search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--us-muted);
        font-size: 15px;
        pointer-events: none;
    }

    .us-search-input {
        width: 100%;
        padding: 11px 40px 11px 40px;
        border: 1.5px solid var(--us-border);
        border-radius: 10px;
        font-family: var(--us-ff);
        font-size: 14px;
        color: var(--us-text);
        background: var(--us-surface);
        outline: none;
        transition: all .2s ease;
    }

        .us-search-input:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,.12);
        }

        .us-search-input::placeholder {
            color: #94a3b8;
        }

    .us-search-clear {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: var(--us-muted);
        display: flex;
        align-items: center;
        padding: 2px;
        border-radius: 4px;
        transition: color .15s;
    }

        .us-search-clear:hover {
            color: var(--us-text);
        }

    /* FILTER CHIPS */
    .us-filter-chips {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .us-chip {
        padding: 8px 16px;
        border-radius: 100px;
        border: 1.5px solid var(--us-border);
        background: var(--us-surface);
        color: var(--us-muted);
        font-family: var(--us-ff);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all .18s ease;
    }

        .us-chip:hover {
            border-color: #6366f1;
            color: #6366f1;
        }

        .us-chip.us-chip-active {
            background: #6366f1;
            border-color: #6366f1;
            color: white;
        }

    /* RESULTS COUNT */
    .us-results-count {
        font-size: 13px;
        color: var(--us-muted);
        margin: 0 0 12px;
    }

    /* TABLE CARD */
    .us-table-card {
        background: var(--us-surface);
        border-radius: var(--us-radius);
        border: 1px solid var(--us-border);
        box-shadow: var(--us-shadow);
        overflow: hidden;
    }

    .us-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

        .us-table thead th {
            padding: 13px 18px;
            background: #f8fafc;
            color: var(--us-muted);
            font-weight: 600;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .07em;
            border-bottom: 1px solid var(--us-border);
            white-space: nowrap;
        }

    .us-row {
        border-bottom: 1px solid var(--us-border);
        transition: background .12s ease;
        animation: usRowIn .35s ease both;
    }

        .us-row:last-child {
            border-bottom: none;
        }

        .us-row:hover {
            background: #f8fafc;
        }

    @@keyframes usRowIn {
        from {
            opacity: 0;
            transform: translateY(6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .us-row td {
        padding: 14px 18px;
        vertical-align: middle;
        color: var(--us-text);
    }

    /* USER CELL */
    .us-user-cell {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .us-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: 700;
        flex-shrink: 0;
        color: white;
    }

    .us-avatar-admin {
        background: linear-gradient(135deg,#ef4444,#dc2626);
    }

    .us-avatar-cliente {
        background: linear-gradient(135deg,#6366f1,#4f46e5);
    }

    .us-avatar-tecnico {
        background: linear-gradient(135deg,#f59e0b,#d97706);
        color: #0f172a;
    }

    .us-user-name {
        display: block;
        font-weight: 600;
        font-size: 14px;
        color: var(--us-text);
    }

    .us-user-email {
        display: block;
        font-size: 12px;
        color: var(--us-muted);
    }

    .us-td-mono {
        font-size: 13px;
        color: var(--us-muted);
        font-variant-numeric: tabular-nums;
    }

    .us-td-date {
        font-size: 13px;
        color: var(--us-muted);
        white-space: nowrap;
    }

    /* ROL BADGE */
    .us-rol-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 12px;
        font-weight: 700;
    }

    .us-rol-admin {
        background: #fee2e2;
        color: #991b1b;
    }

    .us-rol-cliente {
        background: #e0e7ff;
        color: #3730a3;
    }

    .us-rol-tecnico {
        background: #fef3c7;
        color: #92400e;
    }

    /* STATUS */
    .us-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 600;
    }

    .us-status-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .us-status-active .us-status-dot {
        background: #10b981;
        box-shadow: 0 0 0 2px rgba(16,185,129,.25);
    }

    .us-status-active {
        color: #065f46;
    }

    .us-status-inactive .us-status-dot {
        background: #94a3b8;
    }

    .us-status-inactive {
        color: var(--us-muted);
    }

    /* ACTIONS */
    .us-actions {
        display: flex;
        gap: 6px;
    }

    .us-action {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        text-decoration: none;
        transition: all .2s ease;
        border: 1px solid var(--us-border);
        background: white;
    }

    .us-action-edit {
        color: #6366f1;
    }

        .us-action-edit:hover {
            background: #e0e7ff;
            border-color: #6366f1;
            color: #4338ca;
            text-decoration: none;
        }

    .us-action-delete {
        color: #ef4444;
    }

        .us-action-delete:hover {
            background: #fee2e2;
            border-color: #ef4444;
            color: #dc2626;
            text-decoration: none;
        }

    /* NO RESULTS */
    .us-no-results {
        padding: 60px 24px;
        text-align: center;
        color: var(--us-muted);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

        .us-no-results p {
            margin: 0;
            font-size: 15px;
        }

    /* EMPTY */
    .us-empty {
        text-align: center;
        padding: 80px 24px;
        background: var(--us-surface);
        border-radius: var(--us-radius);
        border: 1px dashed var(--us-border);
    }

    .us-empty-icon {
        font-size: 56px;
        margin-bottom: 16px;
    }

    .us-empty h3 {
        font-size: 22px;
        font-weight: 700;
        color: var(--us-text);
        margin-bottom: 8px;
    }

    .us-empty p {
        color: var(--us-muted);
        margin-bottom: 24px;
    }

    /* FORM SHARED */
    .us-form-card {
        background: var(--us-surface);
        border-radius: var(--us-radius);
        box-shadow: var(--us-shadow);
        border: 1px solid var(--us-border);
        padding: 36px;
        max-width: 680px;
    }

    .us-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .us-form-grid-full {
        grid-column: 1/-1;
    }

    .us-form-section {
        margin-bottom: 28px;
    }

    .us-form-section-title {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: #6366f1;
        margin-bottom: 18px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--us-border);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .us-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .us-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--us-muted);
        letter-spacing: .04em;
    }

    .us-input, .us-select {
        padding: 11px 14px;
        border: 1.5px solid var(--us-border);
        border-radius: 10px;
        font-family: var(--us-ff);
        font-size: 14px;
        color: var(--us-text);
        background: var(--us-surface);
        outline: none;
        transition: all .2s ease;
        width: 100%;
    }

        .us-input:focus, .us-select:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,.12);
        }

        .us-input::placeholder {
            color: #94a3b8;
        }

        .us-select option {
            background: white;
        }

    .us-error {
        font-size: 12px;
        color: #ef4444;
    }

    .us-form-actions {
        display: flex;
        gap: 12px;
        margin-top: 28px;
        padding-top: 24px;
        border-top: 1px solid var(--us-border);
    }

    .us-checkbox-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        background: #f8fafc;
        border: 1.5px solid var(--us-border);
        border-radius: 10px;
        cursor: pointer;
        transition: all .2s ease;
    }

        .us-checkbox-wrap:hover {
            border-color: #6366f1;
        }

    .us-checkbox {
        width: 18px;
        height: 18px;
        accent-color: #6366f1;
        cursor: pointer;
    }

    .us-checkbox-label {
        font-size: 14px;
        font-weight: 500;
        color: var(--us-text);
        cursor: pointer;
    }

    /* DELETE */
    .us-detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(200px,1fr));
        gap: 14px;
        margin-bottom: 28px;
    }

    .us-detail-full {
        grid-column: 1/-1;
    }

    .us-detail-item {
        background: #f8fafc;
        border: 1px solid var(--us-border);
        border-radius: 10px;
        padding: 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .us-detail-label {
        font-size: 11px;
        font-weight: 700;
        color: var(--us-muted);
        text-transform: uppercase;
        letter-spacing: .07em;
    }

    .us-detail-value {
        font-size: 15px;
        font-weight: 600;
        color: var(--us-text);
    }

    .us-delete-warning {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px 20px;
        background: #fff7ed;
        border: 1px solid #fed7aa;
        border-radius: 10px;
        color: #9a3412;
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 28px;
    }

        .us-delete-warning i {
            font-size: 22px;
            color: #f97316;
            flex-shrink: 0;
        }

    @@media (max-width:900px) {
        .us-form-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width:768px) {
        .us-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .us-toolbar {
            flex-direction: column;
        }

        .us-table-card {
            overflow-x: auto;
        }
    }
</style>

@section Scripts {
    <script>
        (function () {
            const searchInput  = document.getElementById('us-search');
            const clearBtn     = document.getElementById('us-search-clear');
            const noResults    = document.getElementById('us-no-results');
            const countEl      = document.getElementById('us-results-count');
            const chips        = document.querySelectorAll('.us-chip');
            const allRows      = Array.from(document.querySelectorAll('.us-row'));

            let activeRol  = '';
            let searchTerm = '';

            function updateRows() {
                let visible = 0;

                allRows.forEach((row, i) => {
                    const nombre   = row.dataset.nombre   || '';
                    const cedula   = row.dataset.cedula   || '';
                    const email    = row.dataset.email    || '';
                    const rolLabel = row.dataset.rolLabel || '';
                    const rol      = row.dataset.rol      || '';

                    const matchSearch = !searchTerm ||
                        nombre.includes(searchTerm)   ||
                        cedula.includes(searchTerm)   ||
                        email.includes(searchTerm)    ||
                        rolLabel.includes(searchTerm);

                    const matchRol = !activeRol || rol === activeRol;

                    const show = matchSearch && matchRol;
                    row.style.display = show ? '' : 'none';
                    if (show) {
                        row.style.animationDelay = `${visible * 0.03}s`;
                        visible++;
                    }
                });

                noResults.style.display = visible === 0 ? 'flex' : 'none';
                countEl.textContent = visible === allRows.length
                    ? ''
                    : `${visible} de ${allRows.length} resultado(s)`;
            }

            searchInput.addEventListener('input', function () {
                searchTerm = this.value.toLowerCase().trim();
                clearBtn.style.display = searchTerm ? 'flex' : 'none';
                updateRows();
            });

            clearBtn.addEventListener('click', function () {
                searchInput.value = '';
                searchTerm = '';
                clearBtn.style.display = 'none';
                searchInput.focus();
                updateRows();
            });

            chips.forEach(chip => {
                chip.addEventListener('click', function () {
                    chips.forEach(c => c.classList.remove('us-chip-active'));
                    this.classList.add('us-chip-active');
                    activeRol = this.dataset.rol;
                    updateRows();
                });
            });

            // Animación stagger inicial
            allRows.forEach((row, i) => {
                row.style.animationDelay = `${i * 0.03}s`;
            });
        })();
    </script>
}
