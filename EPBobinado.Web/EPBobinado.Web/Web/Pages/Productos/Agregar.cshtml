@page
@model Web.Pages.Producto.AgregarModel
@{
    ViewData["Title"] = "Agregar Producto";
}

<h2 class="mb-4">Agregar Producto</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <ul class="mb-0">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form method="post">

    <div class="mb-3">
        <label asp-for="Producto.Nombre" class="form-label"></label>
        <input asp-for="Producto.Nombre" class="form-control" placeholder="Nombre del producto" />
        <span asp-validation-for="Producto.Nombre" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Producto.Categoria" class="form-label"></label>
        <input asp-for="Producto.Categoria" class="form-control" placeholder="Ej: Electrónica, Ropa..." />
        <span asp-validation-for="Producto.Categoria" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Producto.Precio" class="form-label"></label>
        <div class="input-group">
            <span class="input-group-text">$</span>
            <input asp-for="Producto.Precio" class="form-control" type="number" step="0.01" min="0.01" />
        </div>
        <span asp-validation-for="Producto.Precio" class="text-danger small"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Producto.Stock" class="form-label"></label>
            <input asp-for="Producto.Stock" class="form-control" type="number" min="0" />
            <span asp-validation-for="Producto.Stock" class="text-danger small"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Producto.StockMinimo" class="form-label"></label>
            <input asp-for="Producto.StockMinimo" class="form-control" type="number" min="0" />
            <span asp-validation-for="Producto.StockMinimo" class="text-danger small"></span>
        </div>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="Producto.Activo" class="form-check-input" type="checkbox" />
        <label asp-for="Producto.Activo" class="form-check-label"></label>
        <span asp-validation-for="Producto.Activo" class="text-danger small d-block"></span>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save"></i> Guardar
        </button>
        <a asp-page="Listado" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Cancelar
        </a>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
