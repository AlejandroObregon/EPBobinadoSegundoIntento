@page
@model Web.Pages.Producto.CatalogoModel
@{
    Layout = "_LayoutUser";
    ViewData["Title"] = "Catálogo de Productos";

    // Mapa de imágenes por categoría (Google Images vía Unsplash proxy estático)
    var imgMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        { "lubricantes",     "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&h=300&fit=crop" },
        { "aceites",         "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&h=300&fit=crop" },
        { "frenos",          "https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?w=400&h=300&fit=crop" },
        { "llantas",         "https://images.unsplash.com/photo-1546614042-7df3c24c9e5d?w=400&h=300&fit=crop" },
        { "neumáticos",      "https://images.unsplash.com/photo-1546614042-7df3c24c9e5d?w=400&h=300&fit=crop" },
        { "neumaticos",      "https://images.unsplash.com/photo-1546614042-7df3c24c9e5d?w=400&h=300&fit=crop" },
        { "filtros",         "https://images.unsplash.com/photo-1619642751034-765dfdf7c58e?w=400&h=300&fit=crop" },
        { "bujias",          "https://images.unsplash.com/photo-1580274455191-1c62238fa333?w=400&h=300&fit=crop" },
        { "bujías",          "https://images.unsplash.com/photo-1580274455191-1c62238fa333?w=400&h=300&fit=crop" },
        { "cadenas",         "https://images.unsplash.com/photo-1558981285-6f0c94958bb6?w=400&h=300&fit=crop" },
        { "correas",         "https://images.unsplash.com/photo-1558981285-6f0c94958bb6?w=400&h=300&fit=crop" },
        { "suspensión",      "https://images.unsplash.com/photo-1565043589221-1a6fd9ae45c7?w=400&h=300&fit=crop" },
        { "suspension",      "https://images.unsplash.com/photo-1565043589221-1a6fd9ae45c7?w=400&h=300&fit=crop" },
        { "electricidad",    "https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=400&h=300&fit=crop" },
        { "eléctrico",       "https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=400&h=300&fit=crop" },
        { "electrico",       "https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=400&h=300&fit=crop" },
        { "accesorios",      "https://images.unsplash.com/photo-1591637333184-19aa84b3e01f?w=400&h=300&fit=crop" },
        { "cascos",          "https://images.unsplash.com/photo-1558618047-3c8c76ca7d13?w=400&h=300&fit=crop" },
        { "herramientas",    "https://images.unsplash.com/photo-1530124566582-a618bc2615dc?w=400&h=300&fit=crop" },
    };

    string GetImg(string cat)
    {
        if (string.IsNullOrWhiteSpace(cat)) return "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&h=300&fit=crop";
        var key = cat.Trim().ToLower();
        foreach (var k in imgMap.Keys)
            if (key.Contains(k) || k.Contains(key)) return imgMap[k];
        return "https://images.unsplash.com/photo-1581090700227-1e37b190418e?w=400&h=300&fit=crop";
    }

    var categorias = Model.Productos
        .Where(p => p.Activo && !string.IsNullOrWhiteSpace(p.Categoria))
        .Select(p => p.Categoria!)
        .Distinct()
        .OrderBy(c => c)
        .ToList();

    var maxPrecio = Model.Productos.Any() ? (int)Math.Ceiling(Model.Productos.Max(p => p.Precio)) : 100000;
}

<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">

<div class="cat-page">

    <!-- HERO -->
    <div class="cat-hero">
        <div class="cat-hero-text">
            <h1 class="cat-hero-title">🛒 Catálogo de Productos</h1>
            <p class="cat-hero-sub">Todo lo que tu moto necesita, en un solo lugar</p>
        </div>
        <div class="cat-hero-stats">
            <div class="cat-hero-stat">
                <span class="cat-hero-num">@Model.Productos.Count(p => p.Activo)</span>
                <span class="cat-hero-lbl">Productos</span>
            </div>
            <div class="cat-hero-stat">
                <span class="cat-hero-num">@categorias.Count</span>
                <span class="cat-hero-lbl">Categorías</span>
            </div>
        </div>
    </div>

    <div class="cat-layout">

        <!-- SIDEBAR FILTROS -->
        <aside class="cat-sidebar">

            <div class="cat-filter-section">
                <p class="cat-filter-title"><i class="bi bi-search"></i> Buscar</p>
                <div class="cat-search-wrap">
                    <input id="cat-search" type="text" class="cat-search-input"
                           placeholder="Nombre del producto..." autocomplete="off" />
                    <button id="cat-search-clear" class="cat-search-clear" style="display:none">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>

            <div class="cat-filter-section">
                <p class="cat-filter-title"><i class="bi bi-grid-3x3-gap"></i> Categoría</p>
                <div class="cat-cat-list">
                    <label class="cat-cat-opt">
                        <input type="radio" name="cat" value="" class="cat-radio" checked />
                        <span class="cat-cat-label">Todas</span>
                        <span class="cat-cat-count">@Model.Productos.Count(p => p.Activo)</span>
                    </label>
                    @foreach (var cat in categorias)
                    {
                        var cnt = Model.Productos.Count(p => p.Activo && p.Categoria == cat);
                        <label class="cat-cat-opt">
                            <input type="radio" name="cat" value="@cat.ToLower()" class="cat-radio" />
                            <span class="cat-cat-label">@cat</span>
                            <span class="cat-cat-count">@cnt</span>
                        </label>
                    }
                </div>
            </div>

            <div class="cat-filter-section">
                <p class="cat-filter-title"><i class="bi bi-currency-dollar"></i> Precio</p>
                <div class="cat-price-inputs">
                    <div class="cat-price-field">
                        <label class="cat-price-lbl">Mínimo</label>
                        <input id="price-min" type="number" class="cat-price-input" value="0" min="0" max="@maxPrecio" />
                    </div>
                    <div class="cat-price-sep">—</div>
                    <div class="cat-price-field">
                        <label class="cat-price-lbl">Máximo</label>
                        <input id="price-max" type="number" class="cat-price-input" value="@maxPrecio" min="0" max="@maxPrecio" />
                    </div>
                </div>
                <input id="range-min" type="range" class="cat-range" min="0" max="@maxPrecio" value="0" step="500" />
                <input id="range-max" type="range" class="cat-range" min="0" max="@maxPrecio" value="@maxPrecio" step="500" />
                <div class="cat-price-display">
                    <span>₡<span id="display-min">0</span></span>
                    <span>₡<span id="display-max">@maxPrecio.ToString("N0")</span></span>
                </div>
            </div>

            <button id="cat-reset" class="cat-reset-btn">
                <i class="bi bi-arrow-counterclockwise"></i> Limpiar filtros
            </button>
        </aside>

        <!-- CONTENIDO -->
        <div class="cat-content">

            <!-- TOOLBAR SUPERIOR -->
            <div class="cat-content-toolbar">
                <p class="cat-result-count" id="cat-count">@Model.Productos.Count(p => p.Activo) producto(s)</p>
                <div class="cat-sort-wrap">
                    <label class="cat-sort-lbl">Ordenar:</label>
                    <select id="cat-sort" class="cat-sort-select">
                        <option value="nombre">Nombre A–Z</option>
                        <option value="nombre-desc">Nombre Z–A</option>
                        <option value="precio-asc">Precio ↑</option>
                        <option value="precio-desc">Precio ↓</option>
                    </select>
                </div>
            </div>

            @if (!Model.Productos.Any(p => p.Activo))
            {
                <div class="cat-empty">
                    <div style="font-size:56px">🏪</div>
                    <h3>Catálogo vacío</h3>
                    <p>No hay productos disponibles en este momento</p>
                </div>
            }
            else
            {
                <!-- GRID DE PRODUCTOS -->
                <div class="cat-grid" id="cat-grid">
                    @foreach (var p in Model.Productos.Where(p => p.Activo).OrderBy(p => p.Nombre))
                    {
                        var img = GetImg(p.Categoria ?? "");
                        var stockBajo = p.Stock <= p.StockMinimo;
                        <div class="cat-card"
                             data-nombre="@p.Nombre.ToLower()"
                             data-cat="@(p.Categoria?.ToLower() ?? "")"
                             data-precio="@p.Precio"
                             data-sort-nombre="@p.Nombre.ToLower()"
                             data-sort-precio="@p.Precio">

                            <div class="cat-card-img-wrap">
                                <img src="@img"
                                     alt="@p.Nombre"
                                     class="cat-card-img"
                                     onerror="this.src='https://images.unsplash.com/photo-1581090700227-1e37b190418e?w=400&h=300&fit=crop'" />
                                @if (!string.IsNullOrWhiteSpace(p.Categoria))
                                {
                                    <span class="cat-card-cat-badge">@p.Categoria</span>
                                }
                                @if (stockBajo && p.Stock > 0)
                                {
                                    <span class="cat-card-low-badge">¡Últimas unidades!</span>
                                }
                                @if (p.Stock == 0)
                                {
                                    <div class="cat-card-agotado">AGOTADO</div>
                                }
                            </div>

                            <div class="cat-card-body">
                                <h3 class="cat-card-name">@p.Nombre</h3>
                                <div class="cat-card-bottom">
                                    <span class="cat-card-price">₡@p.Precio.ToString("N0")</span>
                                    <span class="cat-card-stock @(stockBajo ? "cat-stock-low" : "cat-stock-ok")">
                                        <i class="bi bi-box-seam"></i> @p.Stock en stock
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div id="cat-no-results" class="cat-no-results" style="display:none">
                    <i class="bi bi-search" style="font-size:40px;color:#cbd5e1"></i>
                    <h3>Sin resultados</h3>
                    <p>Intenta con otros filtros o términos de búsqueda</p>
                    <button id="cat-reset2" class="cat-reset-btn" style="margin:0 auto">
                        <i class="bi bi-arrow-counterclockwise"></i> Limpiar filtros
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<style>
    :root {
        --cat-bg: #f8fafc;
        --cat-surface: #fff;
        --cat-border: #e2e8f0;
        --cat-text: #0f172a;
        --cat-muted: #64748b;
        --cat-radius: 14px;
        --cat-shadow: 0 4px 20px rgba(0,0,0,.07);
        --cat-accent: #f59e0b;
        --cat-accent2: #d97706;
        --cat-ff-title: 'Barlow Condensed',sans-serif;
        --cat-ff-body: 'Barlow',sans-serif;
    }

    .cat-page {
        font-family: var(--cat-ff-body);
        min-height: 100vh
    }

    /* HERO */
    .cat-hero {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: linear-gradient(135deg,#0f1923 0%,#1e3a5f 60%,#1a4f8a 100%);
        border-radius: var(--cat-radius);
        padding: 28px 36px;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 20px;
        position: relative;
        overflow: hidden;
    }

        .cat-hero::before {
            content: '🏍️';
            position: absolute;
            right: 200px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 100px;
            opacity: .05;
            pointer-events: none
        }

    .cat-hero-title {
        font-family: var(--cat-ff-title);
        font-size: 32px;
        font-weight: 800;
        color: white;
        margin: 0 0 6px;
        letter-spacing: .5px
    }

    .cat-hero-sub {
        font-size: 15px;
        color: #94a3b8;
        margin: 0
    }

    .cat-hero-stats {
        display: flex;
        gap: 24px
    }

    .cat-hero-stat {
        text-align: center
    }

    .cat-hero-num {
        display: block;
        font-family: var(--cat-ff-title);
        font-size: 36px;
        font-weight: 800;
        color: var(--cat-accent)
    }

    .cat-hero-lbl {
        display: block;
        font-size: 12px;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: .06em
    }

    /* LAYOUT */
    .cat-layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 24px;
        align-items: start
    }

    /* SIDEBAR */
    .cat-sidebar {
        background: var(--cat-surface);
        border-radius: var(--cat-radius);
        border: 1px solid var(--cat-border);
        box-shadow: var(--cat-shadow);
        padding: 0;
        overflow: hidden;
        position: sticky;
        top: 20px;
    }

    .cat-filter-section {
        padding: 20px 20px 16px;
        border-bottom: 1px solid var(--cat-border)
    }

    .cat-filter-title {
        font-family: var(--cat-ff-title);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--cat-muted);
        margin: 0 0 12px;
        display: flex;
        align-items: center;
        gap: 7px
    }

    /* Búsqueda sidebar */
    .cat-search-wrap {
        position: relative
    }

    .cat-search-input {
        width: 100%;
        padding: 10px 36px 10px 12px;
        border: 1.5px solid var(--cat-border);
        border-radius: 9px;
        font-family: var(--cat-ff-body);
        font-size: 14px;
        color: var(--cat-text);
        outline: none;
        transition: all .2s
    }

        .cat-search-input:focus {
            border-color: var(--cat-accent);
            box-shadow: 0 0 0 3px rgba(245,158,11,.12)
        }

        .cat-search-input::placeholder {
            color: #9ca3af
        }

    .cat-search-clear {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: var(--cat-muted);
        display: flex;
        align-items: center;
        padding: 2px
    }

        .cat-search-clear:hover {
            color: var(--cat-text)
        }

    /* Categorías */
    .cat-cat-list {
        display: flex;
        flex-direction: column;
        gap: 4px
    }

    .cat-cat-opt {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 10px;
        border-radius: 8px;
        cursor: pointer;
        transition: background .15s
    }

        .cat-cat-opt:hover {
            background: #f8fafc
        }

    .cat-radio {
        accent-color: var(--cat-accent);
        cursor: pointer;
        width: 15px;
        height: 15px
    }

    .cat-cat-label {
        flex: 1;
        font-size: 14px;
        color: var(--cat-text);
        cursor: pointer
    }

    .cat-cat-count {
        font-size: 12px;
        font-weight: 700;
        color: var(--cat-muted);
        background: #f1f5f9;
        padding: 2px 8px;
        border-radius: 100px
    }

    /* Precio */
    .cat-price-inputs {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px
    }

    .cat-price-field {
        display: flex;
        flex-direction: column;
        gap: 3px;
        flex: 1
    }

    .cat-price-lbl {
        font-size: 11px;
        color: var(--cat-muted);
        font-weight: 600
    }

    .cat-price-input {
        padding: 8px 10px;
        border: 1.5px solid var(--cat-border);
        border-radius: 8px;
        font-size: 13px;
        color: var(--cat-text);
        outline: none;
        width: 100%;
        transition: all .2s
    }

        .cat-price-input:focus {
            border-color: var(--cat-accent)
        }

    .cat-price-sep {
        color: var(--cat-muted);
        font-size: 16px;
        margin-top: 14px
    }

    .cat-range {
        width: 100%;
        accent-color: var(--cat-accent);
        margin: 4px 0;
        cursor: pointer
    }

    .cat-price-display {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        font-weight: 700;
        color: var(--cat-accent2);
        margin-top: 4px;
        font-family: var(--cat-ff-title);
        letter-spacing: .04em
    }

    .cat-reset-btn {
        width: 100%;
        margin: 16px 0 0;
        padding: 11px;
        background: none;
        border: 1.5px solid var(--cat-border);
        border-radius: 9px;
        font-family: var(--cat-ff-body);
        font-size: 13px;
        font-weight: 600;
        color: var(--cat-muted);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        transition: all .2s
    }

        .cat-reset-btn:hover {
            border-color: var(--cat-accent);
            color: var(--cat-accent2)
        }

    .cat-sidebar .cat-reset-btn {
        margin: 12px 20px 20px
    }

    /* CONTENT */
    .cat-content-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        flex-wrap: wrap;
        gap: 10px
    }

    .cat-result-count {
        font-size: 14px;
        color: var(--cat-muted);
        margin: 0;
        font-weight: 600
    }

    .cat-sort-wrap {
        display: flex;
        align-items: center;
        gap: 8px
    }

    .cat-sort-lbl {
        font-size: 13px;
        color: var(--cat-muted)
    }

    .cat-sort-select {
        padding: 8px 12px;
        border: 1.5px solid var(--cat-border);
        border-radius: 8px;
        font-family: var(--cat-ff-body);
        font-size: 13px;
        color: var(--cat-text);
        outline: none;
        cursor: pointer;
        transition: all .2s
    }

        .cat-sort-select:focus {
            border-color: var(--cat-accent)
        }

    /* GRID */
    .cat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(220px,1fr));
        gap: 18px
    }

    /* CARD */
    .cat-card {
        background: var(--cat-surface);
        border-radius: var(--cat-radius);
        border: 1px solid var(--cat-border);
        overflow: hidden;
        transition: all .25s ease;
        animation: catFadeUp .4s ease both;
        display: flex;
        flex-direction: column;
    }

        .cat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 40px rgba(0,0,0,.1);
            border-color: #cbd5e1
        }

    @@keyframes catFadeUp {
        from {
            opacity: 0;
            transform: translateY(12px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    .cat-card-img-wrap {
        position: relative;
        overflow: hidden;
        height: 180px
    }

    .cat-card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform .4s ease
    }

    .cat-card:hover .cat-card-img {
        transform: scale(1.05)
    }

    .cat-card-cat-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: rgba(15,25,35,.75);
        backdrop-filter: blur(6px);
        color: white;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 100px;
        font-family: var(--cat-ff-title);
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .cat-card-low-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background: var(--cat-accent);
        color: #0f1923;
        font-size: 10px;
        font-weight: 800;
        padding: 4px 9px;
        border-radius: 100px;
        font-family: var(--cat-ff-title);
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .cat-card-agotado {
        position: absolute;
        inset: 0;
        background: rgba(15,25,35,.6);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--cat-ff-title);
        font-size: 22px;
        font-weight: 800;
        color: white;
        letter-spacing: 2px;
    }

    .cat-card-body {
        padding: 14px 16px 16px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 10px
    }

    .cat-card-name {
        font-family: var(--cat-ff-title);
        font-size: 16px;
        font-weight: 700;
        color: var(--cat-text);
        margin: 0;
        line-height: 1.3
    }

    .cat-card-bottom {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 8px;
        margin-top: auto
    }

    .cat-card-price {
        font-family: var(--cat-ff-title);
        font-size: 20px;
        font-weight: 800;
        color: var(--cat-accent2)
    }

    .cat-card-stock {
        font-size: 11px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 4px
    }

    .cat-stock-ok {
        color: #10b981
    }

    .cat-stock-low {
        color: #f59e0b
    }

    /* NO RESULTS */
    .cat-no-results {
        padding: 80px 24px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        color: var(--cat-muted)
    }

        .cat-no-results h3 {
            font-family: var(--cat-ff-title);
            font-size: 22px;
            color: var(--cat-text);
            margin: 0
        }

        .cat-no-results p {
            margin: 0
        }

    .cat-empty {
        text-align: center;
        padding: 80px 24px;
        color: var(--cat-muted)
    }

        .cat-empty h3 {
            font-family: var(--cat-ff-title);
            font-size: 22px;
            color: var(--cat-text);
            margin: 8px 0
        }

    @@media(max-width:900px) {
        .cat-layout {
            grid-template-columns: 1fr
        }

        .cat-sidebar {
            position: static
        }

        .cat-grid {
            grid-template-columns: repeat(auto-fill,minmax(180px,1fr))
        }
    }

    @@media(max-width:600px) {
        .cat-hero {
            padding: 20px
        }

        .cat-hero-title {
            font-size: 24px
        }

        .cat-grid {
            grid-template-columns: 1fr 1fr
        }
    }

    @@media(max-width:400px) {
        .cat-grid {
            grid-template-columns: 1fr
        }
    }
</style>

@section Scripts {
    <script>
        (function(){
            const cards     = Array.from(document.querySelectorAll('.cat-card'));
            const grid      = document.getElementById('cat-grid');
            const noResults = document.getElementById('cat-no-results');
            const countEl   = document.getElementById('cat-count');
            const search    = document.getElementById('cat-search');
            const clearBtn  = document.getElementById('cat-search-clear');
            const radios    = document.querySelectorAll('.cat-radio');
            const priceMin  = document.getElementById('price-min');
            const priceMax  = document.getElementById('price-max');
            const rangeMin  = document.getElementById('range-min');
            const rangeMax  = document.getElementById('range-max');
            const dispMin   = document.getElementById('display-min');
            const dispMax   = document.getElementById('display-max');
            const sortSel   = document.getElementById('cat-sort');

            function fmt(n){ return Number(n).toLocaleString('es-CR'); }

            function syncPrice(){
                let lo = parseInt(priceMin.value)||0;
                let hi = parseInt(priceMax.value)||parseInt(rangeMax.max);
                if(lo > hi){ [lo,hi]=[hi,lo]; }
                rangeMin.value = lo; rangeMax.value = hi;
                dispMin.textContent = fmt(lo); dispMax.textContent = fmt(hi);
            }

            rangeMin.addEventListener('input', function(){ priceMin.value=this.value; syncPrice(); applyFilters(); });
            rangeMax.addEventListener('input', function(){ priceMax.value=this.value; syncPrice(); applyFilters(); });
            priceMin.addEventListener('input', function(){ syncPrice(); applyFilters(); });
            priceMax.addEventListener('input', function(){ syncPrice(); applyFilters(); });
            syncPrice();

            function applyFilters(){
                const q   = (search?.value||'').toLowerCase().trim();
                const cat = [...radios].find(r=>r.checked)?.value || '';
                const lo  = parseFloat(priceMin?.value)||0;
                const hi  = parseFloat(priceMax?.value)||Infinity;

                let vis = [];
                cards.forEach(c=>{
                    const nombre = c.dataset.nombre||'';
                    const ccat   = c.dataset.cat||'';
                    const precio = parseFloat(c.dataset.precio)||0;
                    const show   = (!q || nombre.includes(q))
                                 && (!cat || ccat===cat)
                                 && precio>=lo && precio<=hi;
                    c.style.display = show ? '' : 'none';
                    if(show) vis.push(c);
                });

                // Ordenar
                const sort = sortSel?.value||'nombre';
                vis.sort((a,b)=>{
                    if(sort==='nombre')      return a.dataset.sortNombre.localeCompare(b.dataset.sortNombre);
                    if(sort==='nombre-desc') return b.dataset.sortNombre.localeCompare(a.dataset.sortNombre);
                    if(sort==='precio-asc')  return a.dataset.sortPrecio - b.dataset.sortPrecio;
                    if(sort==='precio-desc') return b.dataset.sortPrecio - a.dataset.sortPrecio;
                    return 0;
                });
                vis.forEach((c,i)=>{ c.style.animationDelay=`${i*0.04}s`; grid?.appendChild(c); });

                if(noResults) noResults.style.display = vis.length===0 ? 'flex':'none';
                if(countEl)   countEl.textContent = `${vis.length} producto(s)`;
            }

            search?.addEventListener('input', function(){ clearBtn.style.display=this.value?'flex':'none'; applyFilters(); });
            clearBtn?.addEventListener('click', function(){ search.value=''; this.style.display='none'; search.focus(); applyFilters(); });
            radios.forEach(r=> r.addEventListener('change', applyFilters));
            sortSel?.addEventListener('change', applyFilters);

            // Reset
            function reset(){
                if(search) search.value='';
                if(clearBtn) clearBtn.style.display='none';
                radios.forEach(r=> r.checked = r.value==='');
                if(priceMin){ priceMin.value=0; }
                if(priceMax){ priceMax.value=rangeMax?.max||100000; }
                syncPrice();
                applyFilters();
            }
            document.getElementById('cat-reset')?.addEventListener('click', reset);
            document.getElementById('cat-reset2')?.addEventListener('click', reset);

            // Stagger inicial
            cards.forEach((c,i)=> c.style.animationDelay=`${i*0.04}s`);
        })();
    </script>
}
