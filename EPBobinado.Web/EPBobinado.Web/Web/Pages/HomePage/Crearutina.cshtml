@page
@model Web.Pages.HomePage.Crea_tu_rutinaModel
@{
    Layout = "_LayoutUser";
    ViewData["Title"] = "Crea tu rutina";
}

<section class="section-cta py-5">
    <div class="container py-4">
        <div class="row align-items-center g-5">

            <!-- Texto -->
            <div class="col-12 col-lg-6 order-2 order-lg-1">
                <h1 class="display-5 fw-semibold lh-1 mb-4 title-cta">
                    Crea tu Plan de Entrenamiento<br />
                    Personalizado
                </h1>

                <p class="lead text-cta">
                    ¡Es hora de dar el primer paso hacia tus metas de bienestar!
                    Con FitnessCore, tienes el control total de tu progreso. Simplemente haz
                    clic aquí para registrarte y completa un breve formulario.
                </p>

                <p class="text-cta">
                    Nuestro sistema inteligente diseñará un plan de entrenamiento adaptado
                    específicamente para ti, considerando tu tiempo disponible, nivel de
                    experiencia y los objetivos que deseas alcanzar, ya sea perder grasa,
                    ganar masa muscular o mejorar tu calidad de vida. Empieza hoy mismo a
                    construir la mejor versión de ti.
                </p>

                <a class="btn btn-cta btn-lg px-4 mt-3" href="/Index">
                    Crea mi rutina <span class="ms-2 click-emoji">👆</span>
                </a>




            </div>

            <!-- Imagen -->
            <div class="col-12 col-lg-6 order-1 order-lg-2">
                <div class="img-mask mx-auto">
                    <img src="https://tophealth.es/wp-content/uploads/2022/05/ejercicios-con-pesas.jpg"
                         class="img-fluid w-100 h-100 object-cover shadow-lg"
                         alt="Crea tu plan de entrenamiento con pesas" />
                </div>
            </div>

        </div>
    </div>
</section>

<style>


    .title-cta {
        color: #2f3442;
        letter-spacing: .2px;
        font-family: "Georgia","Times New Roman",serif;
    }

    .text-cta {
        color: #3f4654;
    }

    .btn-cta {
        background: #e9bf93;
        border: 1px solid #b68f6b;
        color: #1f1f1f;
        border-radius: 12px;
        transition: transform .15s ease, box-shadow .2s ease, background .2s ease;
    }

        .btn-cta:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 18px rgba(0,0,0,.08);
            background: #f0caa4;
            color: #1a1a1a;
        }

    .click-emoji {
        display: inline-block;
        animation: bounce 1.1s infinite ease-in-out;
    }

    /* OJO: en Razor se escapa con @@ */
    @@keyframes bounce {
        0%, 100% {
            transform: translateY(0)
        }

        50% {
            transform: translateY(-4px)
        }
    }

    .img-mask {
        border-radius: 2rem;
        overflow: hidden;
        max-width: 680px;
        aspect-ratio: 4/3;
    }

    .object-cover {
        object-fit: cover;
    }

    /* OJO: en Razor se escapa con @@ */
    @@media (max-width: 992px) {
        .img-mask {
            max-width: 560px;
            aspect-ratio: 16/10;
        }
    }
</style>
