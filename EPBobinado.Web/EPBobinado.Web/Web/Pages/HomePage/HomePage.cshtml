@page
@model Web.Pages.HomePage.HomePageModel
@{
    Layout = "_LayoutUser";
    ViewData["Title"] = "Dashboard";
    var userName = HttpContext.Session.GetString("UsuarioNombre") ?? "Usuario";
    var userInitial = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";
    int.TryParse(HttpContext.Session.GetString("UsuarioNivel"), out int rol);
    var rolLabel = rol == 1 ? "Administrador" : rol == 3 ? "Técnico" : "Cliente";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<div class="hp-page">

    <!-- ── WELCOME BANNER ── -->
    <div class="hp-welcome">
        <div class="hp-welcome-left">
            <div class="hp-avatar">@userInitial</div>
            <div>
                <p class="hp-welcome-greeting">Buenos días 👋</p>
                <h1 class="hp-welcome-name">@userName</h1>
                <span class="hp-rol-badge">@rolLabel</span>
            </div>
        </div>
        <a asp-page="/Motores/Agregar" class="hp-btn hp-btn-white">
            <i class="bi bi-plus-lg"></i> Registrar Motor
        </a>
    </div>

    <!-- ── STATS ── -->
    <div class="hp-stats-grid">

        <div class="hp-stat hp-stat-blue">
            <div class="hp-stat-icon">🏍️</div>
            <div class="hp-stat-body">
                <span class="hp-stat-num">@Model.TotalMotores</span>
                <span class="hp-stat-label">Motores</span>
            </div>
            <a asp-page="/Motores/Listado" class="hp-stat-link">Ver →</a>
        </div>

        <div class="hp-stat hp-stat-amber">
            <div class="hp-stat-icon">⏳</div>
            <div class="hp-stat-body">
                <span class="hp-stat-num">@Model.OrdenesActivas</span>
                <span class="hp-stat-label">Órdenes Activas</span>
            </div>
            <a asp-page="/Ordenes/Listado" class="hp-stat-link">Ver →</a>
        </div>

        <div class="hp-stat hp-stat-green">
            <div class="hp-stat-icon">✅</div>
            <div class="hp-stat-body">
                <span class="hp-stat-num">@Model.OrdenesCompletadas</span>
                <span class="hp-stat-label">Completadas</span>
            </div>
            <a asp-page="/Ordenes/Listado" class="hp-stat-link">Ver →</a>
        </div>

        <div class="hp-stat hp-stat-red">
            <div class="hp-stat-icon">🔴</div>
            <div class="hp-stat-body">
                <span class="hp-stat-num">@Model.OrdenesPendientes</span>
                <span class="hp-stat-label">Pendientes</span>
            </div>
            <a asp-page="/Ordenes/Listado" class="hp-stat-link">Ver →</a>
        </div>

    </div>

    <div class="hp-main-grid">

        <!-- ── ÓRDENES ACTIVAS ── -->
        <div class="hp-section">
            <div class="hp-section-header">
                <h2 class="hp-section-title">📋 Órdenes Activas</h2>
                <a asp-page="/Ordenes/Listado" class="hp-link">Ver todas →</a>
            </div>

            @if (!Model.UltimasOrdenes.Any())
            {
                <div class="hp-empty">
                    <span>🎉</span>
                    <p>No hay órdenes activas en este momento</p>
                </div>
            }
            else
            {
                <div class="hp-orders-list">
                    @foreach (var o in Model.UltimasOrdenes)
                    {
                        var slug = o.Estado.ToLower().Replace(" ", "-").Replace("ó", "o").Replace("é", "e");
                        <div class="hp-order-card">
                            <div class="hp-order-left">
                                <div class="hp-order-moto-icon">🏍️</div>
                                <div>
                                    <p class="hp-order-serie">
                                        @(o.Motor?.NumeroSerie ?? $"Motor #{o.MotorId}")
                                        <span class="hp-order-modelo">— @(o.Motor?.Modelo?.Nombre ?? "—")</span>
                                    </p>
                                    <p class="hp-order-meta">
                                        @if (o.Tecnico != null)
                                        {
                                            <span><i class="bi bi-person-gear"></i> @o.Tecnico.Nombre</span>
                                        }
                                        else
                                        {
                                            <span class="hp-no-tecnico">Sin técnico asignado</span>
                                        }
                                        &nbsp;·&nbsp;
                                        <span><i class="bi bi-calendar3"></i> @o.CreadoEn.ToString("dd MMM yyyy")</span>
                                    </p>
                                </div>
                            </div>
                            <div class="hp-order-right">
                                <span class="hp-badge hp-badge-@slug">@o.Estado</span>
                                <a asp-page="/Ordenes/Editar" asp-route-id="@o.Id" class="hp-icon-btn" title="Editar">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ── MIS MOTORES ── -->
        <div class="hp-section">
            <div class="hp-section-header">
                <h2 class="hp-section-title">🏍️ Motores Registrados</h2>
                <a asp-page="/Motores/Listado" class="hp-link">Ver todos →</a>
            </div>

            @if (!Model.MisMotores.Any())
            {
                <div class="hp-empty">
                    <span>🔩</span>
                    <p>No hay motores registrados</p>
                    <a asp-page="/Motores/Agregar" class="hp-btn hp-btn-sm hp-btn-primary">
                        <i class="bi bi-plus-lg"></i> Agregar
                    </a>
                </div>
            }
            else
            {
                <div class="hp-motors-list">
                    @foreach (var m in Model.MisMotores.OrderByDescending(x => x.CreadoEn).Take(5))
                    {
                        var ordenes = Model.TodasLasOrdenes.Count(o => o.MotorId == m.Id);
                        <div class="hp-motor-item">
                            <div class="hp-motor-dot"></div>
                            <div class="hp-motor-info">
                                <p class="hp-motor-serie">
                                    @(string.IsNullOrWhiteSpace(m.NumeroSerie) ? "Sin número de serie" : m.NumeroSerie)
                                </p>
                                <p class="hp-motor-meta">
                                    @(m.Modelo?.Nombre ?? "—")
                                    @if (m.Usuario != null)
                                    {
                                        <span> · @m.Usuario.Nombre</span>
                                    }
                                </p>
                            </div>
                            <div class="hp-motor-right">
                                <span class="hp-motor-badge">@ordenes orden(es)</span>
                                <span class="hp-motor-date">@m.CreadoEn.ToString("dd/MM/yy")</span>
                            </div>
                        </div>
                    }
                    @if (Model.MisMotores.Count > 5)
                    {
                        <div class="hp-more-hint">
                            + @(Model.MisMotores.Count - 5) motor(es) más —
                            <a asp-page="/Motores/Listado">Ver todos</a>
                        </div>
                    }
                </div>
            }
        </div>

    </div>

</div>

<style>
    :root {
        --hp-bg: #f1f5f9;
        --hp-surface: #ffffff;
        --hp-border: #e2e8f0;
        --hp-text: #1e293b;
        --hp-muted: #64748b;
        --hp-radius: 14px;
        --hp-shadow: 0 4px 20px rgba(0,0,0,.07);
        --hp-ff: 'Plus Jakarta Sans', sans-serif;
    }

    .hp-page {
        font-family: var(--hp-ff);
        padding: 0;
    }

    /* ── WELCOME ── */
    .hp-welcome {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
        background: linear-gradient(135deg, #0f1923 0%, #1e3a5f 60%, #1e4d8c 100%);
        border-radius: var(--hp-radius);
        padding: 28px 32px;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
    }

        .hp-welcome::before {
            content: '🏍️';
            position: absolute;
            right: 160px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 90px;
            opacity: .06;
            pointer-events: none;
        }

    .hp-welcome-left {
        display: flex;
        align-items: center;
        gap: 18px;
    }

    .hp-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #f59e0b, #fbbf24);
        color: #0f1923;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        font-weight: 800;
        flex-shrink: 0;
        box-shadow: 0 4px 16px rgba(245,158,11,.35);
    }

    .hp-welcome-greeting {
        font-size: 13px;
        color: #94a3b8;
        margin: 0 0 2px;
    }

    .hp-welcome-name {
        font-size: 26px;
        font-weight: 800;
        color: white;
        margin: 0 0 6px;
    }

    .hp-rol-badge {
        display: inline-block;
        padding: 3px 12px;
        background: rgba(245,158,11,.2);
        border: 1px solid rgba(245,158,11,.4);
        color: #fcd34d;
        border-radius: 100px;
        font-size: 12px;
        font-weight: 600;
    }

    .hp-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 11px 22px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 14px;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: all .2s ease;
        white-space: nowrap;
    }

    .hp-btn-white {
        background: white;
        color: #1e293b;
        box-shadow: 0 4px 12px rgba(0,0,0,.15);
    }

        .hp-btn-white:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,.2);
            color: #1e293b;
            text-decoration: none;
        }

    .hp-btn-primary {
        background: linear-gradient(135deg,#3b82f6,#2563eb);
        color: white;
    }

        .hp-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(59,130,246,.4);
            color: white;
            text-decoration: none;
        }

    .hp-btn-sm {
        padding: 8px 16px;
        font-size: 13px;
    }

    /* ── STATS ── */
    .hp-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 28px;
    }

    .hp-stat {
        background: var(--hp-surface);
        border-radius: var(--hp-radius);
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        border: 1px solid var(--hp-border);
        box-shadow: var(--hp-shadow);
        transition: all .2s ease;
        position: relative;
        overflow: hidden;
    }

        .hp-stat:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0,0,0,.1);
        }

        .hp-stat::after {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            border-radius: 14px 0 0 14px;
        }

    .hp-stat-blue::after {
        background: #3b82f6;
    }

    .hp-stat-amber::after {
        background: #f59e0b;
    }

    .hp-stat-green::after {
        background: #10b981;
    }

    .hp-stat-red::after {
        background: #ef4444;
    }

    .hp-stat-icon {
        font-size: 28px;
        flex-shrink: 0;
    }

    .hp-stat-body {
        flex: 1;
    }

    .hp-stat-num {
        display: block;
        font-size: 32px;
        font-weight: 800;
        color: var(--hp-text);
        line-height: 1;
    }

    .hp-stat-label {
        display: block;
        font-size: 12px;
        color: var(--hp-muted);
        margin-top: 3px;
        font-weight: 500;
    }

    .hp-stat-link {
        display: inline-flex;
        align-items: center;
        font-size: 13px;
        font-weight: 700;
        color: var(--hp-muted);
        text-decoration: none;
        padding: 6px 12px;
        border-radius: 8px;
        background: var(--hp-bg);
        transition: all .2s ease;
        white-space: nowrap;
    }

        .hp-stat-link:hover {
            color: var(--hp-text);
            background: var(--hp-border);
            text-decoration: none;
        }

    /* ── MAIN GRID ── */
    .hp-main-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    /* ── SECTION ── */
    .hp-section {
        background: var(--hp-surface);
        border-radius: var(--hp-radius);
        border: 1px solid var(--hp-border);
        box-shadow: var(--hp-shadow);
        overflow: hidden;
    }

    .hp-section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 22px;
        border-bottom: 1px solid var(--hp-border);
    }

    .hp-section-title {
        font-size: 16px;
        font-weight: 700;
        color: var(--hp-text);
        margin: 0;
    }

    .hp-link {
        font-size: 13px;
        font-weight: 600;
        color: #3b82f6;
        text-decoration: none;
    }

        .hp-link:hover {
            text-decoration: underline;
        }

    /* ── ORDERS LIST ── */
    .hp-orders-list {
        padding: 8px 0;
    }

    .hp-order-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 22px;
        gap: 12px;
        transition: background .15s ease;
        border-bottom: 1px solid var(--hp-border);
    }

        .hp-order-card:last-child {
            border-bottom: none;
        }

        .hp-order-card:hover {
            background: #f8fafc;
        }

    .hp-order-left {
        display: flex;
        align-items: center;
        gap: 12px;
        flex: 1;
        min-width: 0;
    }

    .hp-order-moto-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: linear-gradient(135deg,#1e293b,#334155);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .hp-order-serie {
        font-size: 14px;
        font-weight: 700;
        color: var(--hp-text);
        margin: 0 0 3px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .hp-order-modelo {
        font-weight: 400;
        color: var(--hp-muted);
        font-size: 13px;
    }

    .hp-order-meta {
        font-size: 12px;
        color: var(--hp-muted);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
    }

    .hp-no-tecnico {
        font-style: italic;
    }

    .hp-order-right {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .hp-badge {
        display: inline-block;
        padding: 4px 11px;
        border-radius: 100px;
        font-size: 11px;
        font-weight: 700;
    }

    .hp-badge-pendiente {
        background: #fef3c7;
        color: #92400e;
    }

    .hp-badge-en-diagnostico {
        background: #dbeafe;
        color: #1e40af;
    }

    .hp-badge-en-reparacion {
        background: #ede9fe;
        color: #5b21b6;
    }

    .hp-badge-completado {
        background: #d1fae5;
        color: #065f46;
    }

    .hp-badge-cancelado {
        background: #fee2e2;
        color: #991b1b;
    }

    .hp-icon-btn {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        border: 1px solid var(--hp-border);
        background: white;
        color: #3b82f6;
        text-decoration: none;
        transition: all .15s ease;
    }

        .hp-icon-btn:hover {
            background: #dbeafe;
            border-color: #3b82f6;
            color: #1e40af;
            text-decoration: none;
        }

    /* ── MOTORS LIST ── */
    .hp-motors-list {
        padding: 4px 0;
    }

    .hp-motor-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 22px;
        border-bottom: 1px solid var(--hp-border);
        transition: background .15s ease;
    }

        .hp-motor-item:last-child {
            border-bottom: none;
        }

        .hp-motor-item:hover {
            background: #f8fafc;
        }

    .hp-motor-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: linear-gradient(135deg, #f59e0b, #fbbf24);
        flex-shrink: 0;
    }

    .hp-motor-info {
        flex: 1;
        min-width: 0;
    }

    .hp-motor-serie {
        font-size: 14px;
        font-weight: 700;
        color: var(--hp-text);
        margin: 0 0 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .hp-motor-meta {
        font-size: 12px;
        color: var(--hp-muted);
        margin: 0;
    }

    .hp-motor-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 3px;
        flex-shrink: 0;
    }

    .hp-motor-badge {
        font-size: 11px;
        font-weight: 700;
        background: #f1f5f9;
        color: var(--hp-muted);
        padding: 2px 8px;
        border-radius: 100px;
    }

    .hp-motor-date {
        font-size: 11px;
        color: var(--hp-muted);
    }

    .hp-more-hint {
        font-size: 13px;
        color: var(--hp-muted);
        padding: 12px 22px;
        text-align: center;
    }

        .hp-more-hint a {
            color: #3b82f6;
            text-decoration: none;
            font-weight: 600;
        }

    /* ── EMPTY ── */
    .hp-empty {
        padding: 40px 22px;
        text-align: center;
        color: var(--hp-muted);
        font-size: 14px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

        .hp-empty span {
            font-size: 36px;
        }

    /* ── RESPONSIVE ── */
    @@media (max-width: 1100px) {
        .hp-stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .hp-main-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .hp-welcome {
            flex-direction: column;
            align-items: flex-start;
            padding: 22px;
        }

            .hp-welcome::before {
                display: none;
            }

        .hp-stats-grid {
            grid-template-columns: 1fr 1fr;
        }

        .hp-welcome-name {
            font-size: 22px;
        }
    }

    @@media (max-width: 400px) {
        .hp-stats-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
