@page "{id:int}"
@model Web.Pages.DiagnosticoInicial.EliminarModel
@{
    Layout = "_LayoutUser";
    ViewData["Title"] = "Eliminar Diagnóstico Inicial";
}

<div class="di-page">

    <div class="di-page-header">
        <div>
            <h2 class="di-page-title">🗑️ Eliminar Diagnóstico Inicial</h2>
            <p class="di-page-sub">Esta acción no se puede deshacer</p>
        </div>
        <a asp-page="Listado" class="di-btn di-btn-ghost">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    @if (Model.Diagnostico != null)
    {
        <div class="di-delete-card">
            <div class="di-delete-warning">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>¿Está seguro de que desea eliminar el diagnóstico <strong>#@Model.Diagnostico.Id</strong>?</span>
            </div>

            <div class="di-detail-grid">
                <div class="di-detail-item">
                    <span class="di-detail-label">Orden</span>
                    <span class="di-detail-value">#@Model.Diagnostico.OrdenId</span>
                </div>
                <div class="di-detail-item">
                    <span class="di-detail-label">Estado de Orden</span>
                    <span class="di-detail-value">@(Model.Diagnostico.Orden?.Estado ?? "—")</span>
                </div>
                <div class="di-detail-item">
                    <span class="di-detail-label">Motor</span>
                    <span class="di-detail-value">
                        @(Model.Diagnostico.Orden?.Motor?.NumeroSerie ?? "—")
                    </span>
                </div>
                <div class="di-detail-item">
                    <span class="di-detail-label">Usuario</span>
                    <span class="di-detail-value">
                        @(Model.Diagnostico.Orden?.Motor?.Usuario?.Nombre ?? "—")
                    </span>
                </div>
                <div class="di-detail-item di-detail-full">
                    <span class="di-detail-label">Descripción</span>
                    <span class="di-detail-value">@Model.Diagnostico.Descripcion</span>
                </div>
                <div class="di-detail-item">
                    <span class="di-detail-label">Registrado el</span>
                    <span class="di-detail-value">@Model.Diagnostico.CreadoEn.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>

            <form method="post">
                <input type="hidden" name="id" value="@Model.Diagnostico.Id" />
                <div class="di-form-actions">
                    <button type="submit" asp-page-handler="Eliminar" class="di-btn di-btn-danger">
                        <i class="bi bi-trash"></i> Confirmar Eliminación
                    </button>
                    <a asp-page="Listado" class="di-btn di-btn-ghost">Cancelar</a>
                </div>
            </form>
        </div>
    }
    else
    {
        <div class="di-alert di-alert-warning">
            <i class="bi bi-search"></i> No se encontró el diagnóstico inicial.
        </div>
        <a asp-page="Listado" class="di-btn di-btn-ghost mt-3">Volver al Listado</a>
    }
</div>

<style>
    :root {
        --di-bg: #f1f5f9;
        --di-surface: #fff;
        --di-border: #e2e8f0;
        --di-text: #1e293b;
        --di-muted: #64748b;
        --di-radius: 14px;
        --di-shadow: 0 4px 16px rgba(0,0,0,.07);
        --di-transition: all .2s ease;
    }

    .di-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        gap: 16px
    }

    .di-page-title {
        font-size: 26px;
        font-weight: 700;
        color: var(--di-text);
        margin: 0
    }

    .di-page-sub {
        font-size: 14px;
        color: var(--di-muted);
        margin: 2px 0 0
    }

    .di-alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 14px 18px;
        border-radius: var(--di-radius);
        font-size: 14px;
        margin-bottom: 20px
    }

    .di-alert-warning {
        background: #fffbeb;
        border: 1px solid #fcd34d;
        color: #92400e
    }

    .di-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: var(--di-transition);
        white-space: nowrap
    }

    .di-btn-danger {
        background: linear-gradient(135deg,#ef4444,#dc2626);
        color: white
    }

        .di-btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(239,68,68,.35);
            color: white;
            text-decoration: none
        }

    .di-btn-ghost {
        background: var(--di-surface);
        border: 1px solid var(--di-border);
        color: var(--di-muted)
    }

        .di-btn-ghost:hover {
            background: var(--di-bg);
            color: var(--di-text);
            text-decoration: none
        }

    .di-form-actions {
        display: flex;
        gap: 12px;
        margin-top: 8px
    }

    .di-delete-card {
        background: var(--di-surface);
        border-radius: var(--di-radius);
        box-shadow: var(--di-shadow);
        border: 1px solid var(--di-border);
        padding: 32px
    }

    .di-delete-warning {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px 20px;
        background: #fff7ed;
        border: 1px solid #fed7aa;
        border-radius: 10px;
        color: #9a3412;
        font-size: 15px;
        font-weight: 500;
        margin-bottom: 28px
    }

        .di-delete-warning i {
            font-size: 22px;
            color: #f97316;
            flex-shrink: 0
        }

    .di-detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(200px,1fr));
        gap: 16px;
        margin-bottom: 28px
    }

    .di-detail-full {
        grid-column: 1/-1
    }

    .di-detail-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 14px 16px;
        background: var(--di-bg);
        border-radius: 10px
    }

    .di-detail-label {
        font-size: 11px;
        font-weight: 700;
        color: var(--di-muted);
        text-transform: uppercase;
        letter-spacing: .06em
    }

    .di-detail-value {
        font-size: 15px;
        font-weight: 600;
        color: var(--di-text)
    }

    .di-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 12px;
        font-weight: 700
    }

    .di-badge-pendiente {
        background: #fef3c7;
        color: #92400e
    }

    .di-badge-en-diagnostico {
        background: #dbeafe;
        color: #1e40af
    }

    .di-badge-en-reparacion {
        background: #ede9fe;
        color: #5b21b6
    }

    .di-badge-completado {
        background: #d1fae5;
        color: #065f46
    }

    .di-badge-cancelado {
        background: #fee2e2;
        color: #991b1b
    }
</style>
