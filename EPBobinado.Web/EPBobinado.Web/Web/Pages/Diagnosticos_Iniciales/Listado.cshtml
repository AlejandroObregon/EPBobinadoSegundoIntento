@page
@model Web.Pages.DiagnosticoInicial.ListadoModel
@{
    Layout = "_LayoutUser";
    ViewData["Title"] = "Diagnósticos Iniciales";
}

<div class="di-page">

    <div class="di-page-header">
        <div>
            <h2 class="di-page-title">🔍 Diagnósticos Iniciales</h2>
            <p class="di-page-sub">@Model.Diagnosticos.Count diagnóstico(s) registrado(s)</p>
        </div>
        <a asp-page="Agregar" class="di-btn di-btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Diagnóstico
        </a>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="di-alert di-alert-success">
            <i class="bi bi-check-circle-fill"></i> @TempData["MensajeExito"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="di-alert di-alert-success">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        </div>
    }

    @if (!Model.Diagnosticos.Any())
    {
        <div class="di-empty">
            <div class="di-empty-icon">🔍</div>
            <h3>No hay diagnósticos registrados</h3>
            <p>Registra el primer diagnóstico inicial para comenzar</p>
            <a asp-page="Agregar" class="di-btn di-btn-primary">
                <i class="bi bi-plus-circle"></i> Nuevo Diagnóstico
            </a>
        </div>
    }
    else
    {
        <div class="di-cards-grid">
            @foreach (var d in Model.Diagnosticos.OrderByDescending(x => x.CreadoEn))
            {
                var estadoSlug = (d.Orden?.Estado ?? "").ToLower()
                .Replace(" ", "-").Replace("ó", "o").Replace("é", "e");

                <div class="di-card">
                    <div class="di-card-header">
                        <div class="di-card-id">#@d.Id</div>
                        <span class="di-badge di-badge-@estadoSlug">
                            @(d.Orden?.Estado ?? "Sin estado")
                        </span>
                    </div>

                    <div class="di-card-body">
                        <div class="di-card-meta">
                            <span><i class="bi bi-clipboard-check"></i> Orden <strong>#@d.OrdenId</strong></span>
                            @if (d.Orden?.MotorId != null)
                            {
                                <span><i class="bi bi-motorcycle"></i> @($"Motor #{d.Orden.MotorId}")</span>
                            }
                            @if (d.Orden?.Cliente != null)
                            {
                                <span><i class="bi bi-person"></i> @d.Orden.Cliente</span>
                            }
                        </div>

                        <div class="di-card-desc">
                            @if (d.Descripcion.Length > 150)
                            {
                                @d.Descripcion[..150]
                    
                                <span class="di-desc-more">...</span>
                            }
                            else
                            {
                                @d.Descripcion
                            }
                        </div>
                    </div>

                    <div class="di-card-footer">
                        <span class="di-card-date">
                            <i class="bi bi-calendar3"></i> @d.CreadoEn.ToString("dd/MM/yyyy")
                        </span>
                        <div class="di-actions">
                            <a asp-page="Editar" asp-route-id="@d.Id" class="di-action-btn di-action-edit" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-page="Eliminar" asp-route-id="@d.Id" class="di-action-btn di-action-delete" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    :root {
        --di-bg: #f1f5f9;
        --di-surface: #fff;
        --di-border: #e2e8f0;
        --di-text: #1e293b;
        --di-muted: #64748b;
        --di-radius: 14px;
        --di-shadow: 0 4px 16px rgba(0,0,0,.07);
        --di-transition: all .2s ease;
        --c-pendiente: #f59e0b;
        --c-diagnostico: #3b82f6;
        --c-reparacion: #8b5cf6;
        --c-completado: #10b981;
        --c-cancelado: #ef4444;
    }

    .di-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        gap: 16px;
    }

    .di-page-title {
        font-size: 26px;
        font-weight: 700;
        color: var(--di-text);
        margin: 0;
    }

    .di-page-sub {
        font-size: 14px;
        color: var(--di-muted);
        margin: 2px 0 0;
    }

    .di-alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 14px 18px;
        border-radius: var(--di-radius);
        font-size: 14px;
        margin-bottom: 20px;
    }

    .di-alert-success {
        background: #ecfdf5;
        border: 1px solid #6ee7b7;
        color: #065f46;
    }

    .di-alert-danger {
        background: #fef2f2;
        border: 1px solid #fca5a5;
        color: #991b1b;
    }

    .di-alert-warning {
        background: #fffbeb;
        border: 1px solid #fcd34d;
        color: #92400e;
    }

    .di-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: var(--di-transition);
        white-space: nowrap;
    }

    .di-btn-primary {
        background: linear-gradient(135deg,#3b82f6,#2563eb);
        color: white;
    }

        .di-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(59,130,246,.35);
            color: white;
            text-decoration: none;
        }

    .di-btn-danger {
        background: linear-gradient(135deg,#ef4444,#dc2626);
        color: white;
    }

        .di-btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(239,68,68,.35);
            color: white;
            text-decoration: none;
        }

    .di-btn-ghost {
        background: var(--di-surface);
        border: 1px solid var(--di-border);
        color: var(--di-muted);
    }

        .di-btn-ghost:hover {
            background: var(--di-bg);
            color: var(--di-text);
            text-decoration: none;
        }

    /* CARDS GRID */
    .di-cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 20px;
    }

    .di-card {
        background: var(--di-surface);
        border-radius: var(--di-radius);
        border: 1px solid var(--di-border);
        box-shadow: var(--di-shadow);
        display: flex;
        flex-direction: column;
        transition: var(--di-transition);
        animation: fadeCard .4s ease both;
        overflow: hidden;
    }

        .di-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0,0,0,.1);
        }

    @@keyframes fadeCard {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .di-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px 12px;
        border-bottom: 1px solid var(--di-border);
    }

    .di-card-id {
        font-weight: 700;
        font-size: 18px;
        color: var(--di-text);
    }

    .di-card-body {
        padding: 16px 20px;
        flex: 1;
    }

    .di-card-meta {
        display: flex;
        flex-direction: column;
        gap: 5px;
        margin-bottom: 14px;
        font-size: 13px;
        color: var(--di-muted);
    }

        .di-card-meta span {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .di-card-meta i {
            color: #94a3b8;
        }

        .di-card-meta strong {
            color: var(--di-text);
        }

    .di-card-desc {
        font-size: 14px;
        color: #334155;
        line-height: 1.6;
        background: #f8fafc;
        border-radius: 8px;
        padding: 12px 14px;
        border-left: 3px solid #3b82f6;
    }

    .di-desc-more {
        color: var(--di-muted);
    }

    .di-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 20px;
        border-top: 1px solid var(--di-border);
        background: #f8fafc;
    }

    .di-card-date {
        font-size: 12px;
        color: var(--di-muted);
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .di-actions {
        display: flex;
        gap: 6px;
    }

    .di-action-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        text-decoration: none;
        transition: var(--di-transition);
        border: 1px solid var(--di-border);
        background: white;
    }

    .di-action-edit {
        color: #3b82f6;
    }

        .di-action-edit:hover {
            background: #dbeafe;
            border-color: #3b82f6;
            color: #1e40af;
            text-decoration: none;
        }

    .di-action-delete {
        color: #ef4444;
    }

        .di-action-delete:hover {
            background: #fee2e2;
            border-color: #ef4444;
            color: #991b1b;
            text-decoration: none;
        }

    /* BADGES */
    .di-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 12px;
        font-weight: 700;
    }

    .di-badge-pendiente {
        background: #fef3c7;
        color: #92400e;
    }

    .di-badge-en-diagnostico {
        background: #dbeafe;
        color: #1e40af;
    }

    .di-badge-en-reparacion {
        background: #ede9fe;
        color: #5b21b6;
    }

    .di-badge-completado {
        background: #d1fae5;
        color: #065f46;
    }

    .di-badge-cancelado {
        background: #fee2e2;
        color: #991b1b;
    }

    .di-badge-sin-estado {
        background: #f1f5f9;
        color: #64748b;
    }

    /* EMPTY */
    .di-empty {
        text-align: center;
        padding: 80px 24px;
        background: white;
        border-radius: var(--di-radius);
        border: 1px dashed var(--di-border);
    }

    .di-empty-icon {
        font-size: 56px;
        margin-bottom: 16px;
    }

    .di-empty h3 {
        font-size: 20px;
        font-weight: 700;
        color: var(--di-text);
        margin-bottom: 8px;
    }

    .di-empty p {
        color: var(--di-muted);
        margin-bottom: 24px;
    }

    /* FORM (agregar/editar/eliminar) */
    .di-form-card {
        background: var(--di-surface);
        border-radius: var(--di-radius);
        box-shadow: var(--di-shadow);
        border: 1px solid var(--di-border);
        padding: 32px;
    }

    .di-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 24px;
    }

    .di-label {
        font-size: 13px;
        font-weight: 600;
        color: #475569;
    }

    .di-select, .di-textarea {
        padding: 11px 14px;
        border: 1px solid var(--di-border);
        border-radius: 10px;
        font-size: 14px;
        color: var(--di-text);
        background: white;
        transition: var(--di-transition);
        outline: none;
        width: 100%;
    }

        .di-select:focus, .di-textarea:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,.12);
        }

    .di-textarea {
        resize: vertical;
        font-family: inherit;
        line-height: 1.6;
    }

    .di-error {
        font-size: 12px;
        color: #ef4444;
    }

    .di-form-actions {
        display: flex;
        gap: 12px;
        margin-top: 8px;
    }

    /* DELETE */
    .di-delete-card {
        background: var(--di-surface);
        border-radius: var(--di-radius);
        box-shadow: var(--di-shadow);
        border: 1px solid var(--di-border);
        padding: 32px;
    }

    .di-delete-warning {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px 20px;
        background: #fff7ed;
        border: 1px solid #fed7aa;
        border-radius: 10px;
        color: #9a3412;
        font-size: 15px;
        font-weight: 500;
        margin-bottom: 28px;
    }

        .di-delete-warning i {
            font-size: 22px;
            color: #f97316;
            flex-shrink: 0;
        }

    .di-detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 16px;
        margin-bottom: 28px;
    }

    .di-detail-full {
        grid-column: 1 / -1;
    }

    .di-detail-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 14px 16px;
        background: var(--di-bg);
        border-radius: 10px;
    }

    .di-detail-label {
        font-size: 11px;
        font-weight: 700;
        color: var(--di-muted);
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .di-detail-value {
        font-size: 15px;
        font-weight: 600;
        color: var(--di-text);
    }

    @@media (max-width: 768px) {
        .di-page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .di-cards-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
