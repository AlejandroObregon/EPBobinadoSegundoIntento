        }
    }

    @@media(max-width:480px) {
        .pr-stats {
            grid-template-columns: 1fr 1fr
        }
    }
</style>

@section Scripts {
    <script>
        (function(){
            const search   = document.getElementById('pr-search');
            const clearBtn = document.getElementById('pr-clear');
            const catSel   = document.getElementById('pr-cat-filter');
            const estSel   = document.getElementById('pr-estado-filter');
            const rows     = Array.from(document.querySelectorAll('.pr-row'));
            const noRes    = document.getElementById('pr-no-results');
            const countEl  = document.getElementById('pr-count');

            function filter() {
                const q   = (search?.value || '').toLowerCase().trim();
                const cat = catSel?.value  || '';
                const est = estSel?.value  || '';
                let vis = 0;
                rows.forEach((row, i) => {
                    const matchQ   = !q   || row.dataset.nombre.includes(q) || row.dataset.cat.includes(q);
                    const matchCat = !cat || row.dataset.cat === cat;
                    const matchEst = !est || row.dataset.activo === est || (est === 'bajo' && row.dataset.stock === 'bajo');
                    const show = matchQ && matchCat && matchEst;
                    row.style.display = show ? '' : 'none';
                    if(show){ row.style.animationDelay = `${vis*0.03}s`; vis++; }
                });
                if(noRes) noRes.style.display = vis === 0 ? 'flex' : 'none';
                if(countEl) countEl.textContent = vis === rows.length ? '' : `${vis} de ${rows.length} resultado(s)`;
            }

            search?.addEventListener('input', function(){ clearBtn.style.display = this.value ? 'flex':'none'; filter(); });
            clearBtn?.addEventListener('click', function(){ search.value=''; this.style.display='none'; search.focus(); filter(); });
            catSel?.addEventListener('change', filter);
            estSel?.addEventListener('change', filter);
            rows.forEach((r,i)=> r.style.animationDelay=`${i*0.03}s`);
        })();
    </script>
}
