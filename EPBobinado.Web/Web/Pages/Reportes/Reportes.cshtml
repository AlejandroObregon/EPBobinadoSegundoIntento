@page "/Reportes"
@model Web.Pages.Reportes.ReportesModel
@{
    Layout = "_LayoutUser";
    ViewData["Title"] = "Reportes";
}

<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<div class="rp-page">

    <div class="rp-header">
        <div class="rp-header-left">
            <div class="rp-header-icon">📊</div>
            <div>
                <h1 class="rp-title">REPORTES</h1>
                <p class="rp-subtitle">Métricas generales del taller</p>
            </div>
        </div>
        <div class="rp-header-actions">
            <span class="rp-date"><i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dd 'de' MMMM, yyyy")</span>
            <button onclick="abrirModalPDF()" class="rp-btn rp-btn-export">
                <i class="bi bi-file-earmark-pdf-fill"></i> Exportar PDF
            </button>
        </div>
    </div>

    <!-- MODAL PARA PARÁMETROS DEL PDF -->
    <div id="pdfModal" class="rp-modal" style="display:none;">
        <div class="rp-modal-content">
            <div class="rp-modal-header">
                <h3><i class="bi bi-file-earmark-pdf-fill"></i> Exportar Reporte PDF</h3>
                <button class="rp-modal-close" onclick="cerrarModalPDF()">&times;</button>
            </div>
            <div class="rp-modal-body">
                <div class="rp-modal-section">
                    <label class="rp-modal-label">📅 Rango de fechas</label>
                    <div class="rp-modal-row">
                        <div class="rp-modal-field">
                            <label>Desde:</label>
                            <input type="date" id="pdfFechaDesde" class="rp-modal-input">
                        </div>
                        <div class="rp-modal-field">
                            <label>Hasta:</label>
                            <input type="date" id="pdfFechaHasta" class="rp-modal-input">
                        </div>
                    </div>
                </div>

                <div class="rp-modal-section">
                    <label class="rp-modal-label">📊 Seleccione qué incluir</label>
                    <div class="rp-modal-check-group">
                        <label><input type="checkbox" id="pdfIncluirKPIs" checked> KPIs globales</label>
                        <label><input type="checkbox" id="pdfIncluirOrdenes" checked> Órdenes por estado</label>
                        <label><input type="checkbox" id="pdfIncluirMotores" checked> Motores por modelo</label>
                        <label><input type="checkbox" id="pdfIncluirInventario" checked> Resumen inventario</label>
                        <label><input type="checkbox" id="pdfIncluirVentas" checked> Ventas</label>
                    </div>
                </div>

                <div class="rp-modal-section">
                    <label class="rp-modal-label">🎨 Formato del reporte</label>
                    <div class="rp-modal-row">
                        <div class="rp-modal-field">
                            <label>Orientación:</label>
                            <select id="pdfOrientacion" class="rp-modal-input">
                                <option value="landscape">Horizontal (Landscape)</option>
                                <option value="portrait">Vertical (Portrait)</option>
                            </select>
                        </div>
                        <div class="rp-modal-field">
                            <label>Tamaño:</label>
                            <select id="pdfTamano" class="rp-modal-input">
                                <option value="letter">Carta (Letter)</option>
                                <option value="a4">A4</option>
                                <option value="legal">Oficio (Legal)</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="rp-modal-section">
                    <label class="rp-modal-label">📝 Información adicional</label>
                    <textarea id="pdfNotas" class="rp-modal-textarea" rows="2"
                              placeholder="Notas adicionales para incluir en el reporte (opcional)..."></textarea>
                </div>
            </div>
            <div class="rp-modal-footer">
                <button class="rp-btn rp-btn-secondary" onclick="cerrarModalPDF()">Cancelar</button>
                <button class="rp-btn rp-btn-primary" onclick="generarPDFConParametros(this)">
                    <i class="bi bi-download"></i> Generar PDF
                </button>
            </div>
        </div>
    </div>

    <!-- KPIs GLOBALES -->
    <div class="rp-kpis">
        <div class="rp-kpi rp-kpi-blue">
            <div class="rp-kpi-icon"><i class="bi bi-clipboard-check-fill"></i></div>
            <div><span class="rp-kpi-num">@Model.TotalOrdenes</span><span class="rp-kpi-lbl">Total órdenes</span></div>
        </div>
        <div class="rp-kpi rp-kpi-amber">
            <div class="rp-kpi-icon"><i class="bi bi-clock-fill"></i></div>
            <div><span class="rp-kpi-num">@Model.OrdenesActivas</span><span class="rp-kpi-lbl">Activas</span></div>
        </div>
        <div class="rp-kpi rp-kpi-green">
            <div class="rp-kpi-icon"><i class="bi bi-check-circle-fill"></i></div>
            <div><span class="rp-kpi-num">@Model.OrdenesCompletadas</span><span class="rp-kpi-lbl">Completadas</span></div>
        </div>
        <div class="rp-kpi rp-kpi-purple">
            <div class="rp-kpi-icon"><i class="bi bi-people-fill"></i></div>
            <div><span class="rp-kpi-num">@Model.TotalClientes</span><span class="rp-kpi-lbl">Clientes</span></div>
        </div>
        <div class="rp-kpi rp-kpi-dark">
            <div class="rp-kpi-icon"><i class="bi bi-gear-wide-connected"></i></div>
            <div><span class="rp-kpi-num">@Model.TotalMotores</span><span class="rp-kpi-lbl">Motores</span></div>
        </div>
        <div class="rp-kpi rp-kpi-red">
            <div class="rp-kpi-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <div><span class="rp-kpi-num">@Model.ProductosBajoStock</span><span class="rp-kpi-lbl">Stock bajo</span></div>
        </div>
    </div>

    <!-- TABS -->
    <div class="rp-tabs">
        <button class="rp-tab active" onclick="cambiarTab('ordenes',this)">
            <i class="bi bi-clipboard-data-fill"></i> Órdenes
        </button>
        <button class="rp-tab" onclick="cambiarTab('motores',this)">
            <i class="bi bi-gear-wide-connected"></i> Motores
        </button>
        <button class="rp-tab" onclick="cambiarTab('inventario',this)">
            <i class="bi bi-box-seam-fill"></i> Inventario
        </button>
        <button class="rp-tab" onclick="cambiarTab('ventas',this)">
            <i class="bi bi-currency-dollar"></i> Ventas &amp; Pagos
        </button>
    </div>

    <div id="dashboard">

        <!-- ══ TAB ÓRDENES ══ -->
        <div class="rp-panel" id="panel-ordenes">
            <div class="rp-filters">
                <div class="rp-filter-group">
                    <label class="rp-filter-lbl"><i class="bi bi-calendar-range"></i> Desde</label>
                    <input type="date" id="ord-desde" class="rp-filter-input" onchange="filtrarOrdenes()">
                </div>
                <div class="rp-filter-group">
                    <label class="rp-filter-lbl">Hasta</label>
                    <input type="date" id="ord-hasta" class="rp-filter-input" onchange="filtrarOrdenes()">
                </div>
                <div class="rp-filter-group">
                    <label class="rp-filter-lbl"><i class="bi bi-funnel"></i> Estado</label>
                    <select id="ord-estado" class="rp-filter-input" onchange="filtrarOrdenes()">
                        <option value="">Todos</option>
                        <option value="Pendiente">Pendiente</option>
                        <option value="En diagnóstico">En diagnóstico</option>
                        <option value="En reparación">En reparación</option>
                        <option value="Completado">Completado</option>
                        <option value="Cancelado">Cancelado</option>
                    </select>
                </div>
                <button class="rp-filter-clear" onclick="limpiarFiltrosOrdenes()">
                    <i class="bi bi-x-circle"></i> Limpiar
                </button>
                <span class="rp-filter-result" id="ord-result"></span>
            </div>

            <div class="rp-grid-2">
                <div class="rp-card">
                    <div class="rp-card-header">
                        <h3 class="rp-card-title">Distribución por estado</h3>
                    </div>
                    <div class="rp-chart-wrap" style="height:220px">
                        <canvas id="chartEstados"></canvas>
                    </div>
                </div>
                <div class="rp-card">
                    <div class="rp-card-header">
                        <h3 class="rp-card-title">Tendencia mensual</h3>
                        <span class="rp-card-sub">Últimos 6 meses</span>
                    </div>
                    <div class="rp-chart-wrap" style="height:220px">
                        <canvas id="chartMeses"></canvas>
                    </div>
                </div>
            </div>
            <div class="rp-card">
                <div class="rp-card-header">
                    <h3 class="rp-card-title">Órdenes por técnico</h3>
                    <span class="rp-card-sub">Top 8</span>
                </div>
                <div class="rp-chart-wrap" style="height:200px">
                    <canvas id="chartTecnicos"></canvas>
                </div>
            </div>
        </div>

        <!-- ══ TAB MOTORES ══ -->
        <div class="rp-panel" id="panel-motores" style="display:none">
            <div class="rp-filters">
                <div class="rp-filter-group">
                    <label class="rp-filter-lbl"><i class="bi bi-search"></i> Buscar modelo</label>
                    <input type="text" id="mot-buscar" class="rp-filter-input"
                           placeholder="Ej: Siemens, WEG…"
                           oninput="filtrarMotores()">
                </div>
                <div class="rp-filter-group">
                    <label class="rp-filter-lbl"><i class="bi bi-sort-down"></i> Ordenar por</label>
                    <select id="mot-orden" class="rp-filter-input" onchange="filtrarMotores()">
                        <option value="desc">Mayor cantidad primero</option>
                        <option value="asc">Menor cantidad primero</option>
                        <option value="az">Nombre A→Z</option>
                    </select>
                </div>
                <button class="rp-filter-clear" onclick="limpiarFiltrosMotores()">
                    <i class="bi bi-x-circle"></i> Limpiar
                </button>
                <span class="rp-filter-result" id="mot-result"></span>
            </div>

            <div class="rp-grid-2">
                <div class="rp-card">
                    <div class="rp-card-header">
                        <h3 class="rp-card-title">Motores por modelo</h3>
                        <span class="rp-card-sub" id="mot-sub-bar">Top 8</span>
                    </div>
                    <div class="rp-chart-wrap" style="height:240px">
                        <canvas id="chartModelos"></canvas>
                    </div>
                </div>
                <div class="rp-card">
                    <div class="rp-card-header">
                        <h3 class="rp-card-title">Distribución por modelo</h3>
                        <span class="rp-card-sub">Top 5 + Otros</span>
                    </div>
                    <div class="rp-chart-wrap" style="height:240px">
                        <canvas id="chartMotDist"></canvas>
                    </div>
                </div>
            </div>

            <div class="rp-card" id="card-masServiciados">
                <div class="rp-card-header">
                    <h3 class="rp-card-title">Motores por cliente</h3>
                    <span class="rp-card-sub">Top 8 — cantidad de motores por dueño</span>
                </div>
                <div class="rp-chart-wrap" style="height:200px">
                    <canvas id="chartMasServiciados"></canvas>
                </div>
            </div>
        </div>

        <!-- ══ TAB INVENTARIO ══ -->
        <div class="rp-panel" id="panel-inventario" style="display:none">
            <div class="rp-filters">
                <div class="rp-filter-group">
                    <label class="rp-filter-lbl"><i class="bi bi-tag"></i> Categoría</label>
                    <select id="inv-cat" class="rp-filter-input" onchange="filtrarInventario()">
                        <option value="">Todas</option>
                    </select>
                </div>
                <div class="rp-filter-group">
                    <label class="rp-filter-lbl"><i class="bi bi-funnel"></i> Ver</label>
                    <select id="inv-modo" class="rp-filter-input" onchange="filtrarInventario()">
                        <option value="todos">Todos los productos</option>
                        <option value="bajos">Solo bajo stock</option>
                    </select>
                </div>
                <button class="rp-filter-clear" onclick="limpiarFiltrosInventario()">
                    <i class="bi bi-x-circle"></i> Limpiar
                </button>
                <span class="rp-filter-result" id="inv-result"></span>
            </div>

            <div class="rp-grid-2">
                <div class="rp-card">
                    <div class="rp-card-header">
                        <h3 class="rp-card-title">Stock por categoría</h3>
                        <span class="rp-card-sub">Unidades disponibles</span>
                    </div>
                    <div class="rp-chart-wrap" style="height:220px"><canvas id="chartStock"></canvas></div>
                </div>
                <div class="rp-card">
                    <div class="rp-card-header">
                        <h3 class="rp-card-title">Productos con menos stock</h3>
                        <span class="rp-card-sub rp-sub-red">⚠ Top 6 más bajos</span>
                    </div>
                    <div class="rp-chart-wrap" style="height:220px"><canvas id="chartBajos"></canvas></div>
                </div>
            </div>
        </div>

        <!-- ══ TAB VENTAS ══ -->
        <div class="rp-panel" id="panel-ventas" style="display:none">

            <div class="rp-filters">
                <div class="rp-filter-group">
                    <label class="rp-filter-lbl"><i class="bi bi-calendar-range"></i> Desde mes</label>
                    <select id="ven-desde" class="rp-filter-input" onchange="filtrarVentas()"></select>
                </div>
                <div class="rp-filter-group">
                    <label class="rp-filter-lbl">Hasta mes</label>
                    <select id="ven-hasta" class="rp-filter-input" onchange="filtrarVentas()"></select>
                </div>
                <button class="rp-filter-clear" onclick="limpiarFiltrosVentas()">
                    <i class="bi bi-x-circle"></i> Limpiar
                </button>
                <span class="rp-filter-result" id="ven-result"></span>
            </div>

            <div class="rp-kpis-ventas">
                <div class="rp-kpi-v rp-kpi-v-green">
                    <span class="rp-kpi-v-lbl">Ingresos en rango</span>
                    <span class="rp-kpi-v-num" id="ven-kpi-total">₡@Model.VentasTotalMes.ToString("N0")</span>
                    <span class="rp-kpi-v-sub" id="ven-kpi-sub">Mes más reciente</span>
                </div>
                <div class="rp-kpi-v rp-kpi-v-blue">
                    <span class="rp-kpi-v-lbl">Ticket promedio</span>
                    <span class="rp-kpi-v-num">₡@Model.TicketPromedio.ToString("N0")</span>
                    <span class="rp-kpi-v-sub">Por orden de servicio</span>
                </div>
                <div class="rp-kpi-v rp-kpi-v-amber">
                    <span class="rp-kpi-v-lbl">Pagos pendientes</span>
                    <span class="rp-kpi-v-num">@Model.PagosPendientes</span>
                    <span class="rp-kpi-v-sub">Cotizaciones sin cobrar</span>
                </div>
            </div>
            <div class="rp-card">
                <div class="rp-card-header">
                    <h3 class="rp-card-title">Ingresos por mes</h3>
                    <span class="rp-card-sub">Período seleccionado (₡)</span>
                </div>
                <div class="rp-chart-wrap" style="height:220px"><canvas id="chartVentasMes"></canvas></div>
            </div>
            <div class="rp-grid-2">
                <div class="rp-card">
                    <div class="rp-card-header">
                        <h3 class="rp-card-title">Pagos por método</h3>
                    </div>
                    <div class="rp-chart-wrap" style="height:220px">
                        <canvas id="chartMetodoPago"></canvas>
                    </div>
                </div>
                <div class="rp-card">
                    <div class="rp-card-header">
                        <h3 class="rp-card-title">Ingresos por tipo de servicio</h3>
                    </div>
                    <div class="rp-chart-wrap" style="height:220px"><canvas id="chartServicios"></canvas></div>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    :root {
        --rp-surface: #fff;
        --rp-border: #e2e8f0;
        --rp-text: #0f172a;
        --rp-muted: #64748b;
        --rp-radius: 14px;
        --rp-shadow: 0 4px 20px rgba(0,0,0,.07);
        --rp-ff: 'Barlow Condensed',sans-serif;
        --rp-ff-body: 'Barlow',sans-serif;
        --rp-amber: #f59e0b;
    }

    .rp-page {
        font-family: var(--rp-ff-body);
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .rp-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
    }

    .rp-header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .rp-header-actions {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .rp-header-icon {
        font-size: 44px;
    }

    .rp-title {
        font-family: var(--rp-ff);
        font-size: 40px;
        font-weight: 800;
        letter-spacing: 2px;
        color: var(--rp-text);
        margin: 0;
    }

    .rp-subtitle {
        font-size: 12px;
        color: var(--rp-muted);
        text-transform: uppercase;
        letter-spacing: .06em;
        margin: 4px 0 0;
    }

    .rp-date {
        font-size: 13px;
        color: var(--rp-muted);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .rp-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 18px;
        border-radius: 9px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        transition: all .2s;
    }

    .rp-btn-export {
        background: linear-gradient(135deg,#ef4444,#dc2626);
        color: #fff;
    }

        .rp-btn-export:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(239,68,68,.35);
        }

    .rp-btn-primary {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: white;
    }

    .rp-btn-secondary {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

        .rp-btn-primary:hover, .rp-btn-secondary:hover {
            transform: translateY(-1px);
        }

    /* MODAL */
    .rp-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .rp-modal-content {
        background: white;
        border-radius: 20px;
        width: 90%;
        max-width: 550px;
        max-height: 85vh;
        overflow-y: auto;
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        animation: modalSlideIn 0.3s ease;
    }

    @@keyframes modalSlideIn {
        from {
            transform: translateY(-30px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .rp-modal-header {
        padding: 20px 24px;
        border-bottom: 2px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .rp-modal-header h3 {
            margin: 0;
            font-family: var(--rp-ff);
            font-size: 22px;
            font-weight: 700;
            color: #1e293b;
        }

    .rp-modal-close {
        background: none;
        border: none;
        font-size: 32px;
        cursor: pointer;
        color: #94a3b8;
        transition: color 0.2s;
    }

        .rp-modal-close:hover {
            color: #ef4444;
        }

    .rp-modal-body {
        padding: 24px;
    }

    .rp-modal-section {
        margin-bottom: 24px;
    }

    .rp-modal-label {
        display: block;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 12px;
        font-size: 14px;
    }

    .rp-modal-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .rp-modal-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .rp-modal-field label {
            font-size: 12px;
            color: #64748b;
            font-weight: 500;
        }

    .rp-modal-input {
        padding: 10px 12px;
        border: 1.5px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        transition: border-color 0.2s;
    }

        .rp-modal-input:focus {
            outline: none;
            border-color: #f59e0b;
        }

    .rp-modal-check-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

        .rp-modal-check-group label {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            font-size: 14px;
            color: #334155;
        }

        .rp-modal-check-group input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: #f59e0b;
        }

    .rp-modal-textarea {
        width: 100%;
        padding: 10px 12px;
        border: 1.5px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        font-family: inherit;
        resize: vertical;
    }

    .rp-modal-footer {
        padding: 16px 24px;
        border-top: 1px solid #e2e8f0;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    /* KPIs */
    .rp-kpis {
        display: grid;
        grid-template-columns: repeat(6,1fr);
        gap: 14px;
    }

    .rp-kpi {
        background: var(--rp-surface);
        border: 1.5px solid var(--rp-border);
        border-radius: 12px;
        padding: 16px 18px;
        display: flex;
        align-items: center;
        gap: 14px;
        position: relative;
        overflow: hidden;
        transition: transform .2s;
    }

        .rp-kpi:hover {
            transform: translateY(-2px);
            box-shadow: var(--rp-shadow);
        }

        .rp-kpi::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            border-radius: 12px 0 0 12px;
        }

    .rp-kpi-blue::before {
        background: #3b82f6;
    }

    .rp-kpi-amber::before {
        background: #f59e0b;
    }

    .rp-kpi-green::before {
        background: #10b981;
    }

    .rp-kpi-purple::before {
        background: #8b5cf6;
    }

    .rp-kpi-dark::before {
        background: #334155;
    }

    .rp-kpi-red::before {
        background: #ef4444;
    }

    .rp-kpi-icon {
        font-size: 22px;
        flex-shrink: 0;
    }

    .rp-kpi-blue .rp-kpi-icon {
        color: #3b82f6;
    }

    .rp-kpi-amber .rp-kpi-icon {
        color: #f59e0b;
    }

    .rp-kpi-green .rp-kpi-icon {
        color: #10b981;
    }

    .rp-kpi-purple .rp-kpi-icon {
        color: #8b5cf6;
    }

    .rp-kpi-dark .rp-kpi-icon {
        color: #334155;
    }

    .rp-kpi-red .rp-kpi-icon {
        color: #ef4444;
    }

    .rp-kpi-num {
        display: block;
        font-family: var(--rp-ff);
        font-size: 30px;
        font-weight: 800;
        color: var(--rp-text);
        line-height: 1.1;
    }

    .rp-kpi-lbl {
        display: block;
        font-size: 11px;
        color: var(--rp-muted);
        text-transform: uppercase;
        letter-spacing: .05em;
        margin-top: 2px;
    }

    /* TABS */
    .rp-tabs {
        display: flex;
        gap: 4px;
        background: #f1f5f9;
        padding: 5px;
        border-radius: 12px;
        flex-wrap: wrap;
    }

    .rp-tab {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 9px 18px;
        border-radius: 9px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        background: transparent;
        color: var(--rp-muted);
        transition: all .2s;
        white-space: nowrap;
    }

        .rp-tab:hover {
            color: var(--rp-text);
            background: rgba(255,255,255,.7);
        }

        .rp-tab.active {
            background: #fff;
            color: var(--rp-text);
            box-shadow: 0 2px 8px rgba(0,0,0,.08);
        }

    .rp-tab-badge {
        font-size: 10px;
        background: #f59e0b;
        color: #0f1923;
        padding: 1px 7px;
        border-radius: 100px;
        font-weight: 700;
    }

    /* FILTERS */
    .rp-filters {
        display: flex;
        align-items: flex-end;
        gap: 12px;
        padding: 16px 20px;
        background: #f8fafc;
        border: 1.5px solid var(--rp-border);
        border-radius: 12px;
        flex-wrap: wrap;
    }

    .rp-filter-group {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .rp-filter-lbl {
        font-size: 11px;
        font-weight: 700;
        color: var(--rp-muted);
        text-transform: uppercase;
        letter-spacing: .05em;
    }

    .rp-filter-input {
        padding: 8px 12px;
        border: 1.5px solid var(--rp-border);
        border-radius: 8px;
        font-size: 13px;
        color: var(--rp-text);
        background: #fff;
        outline: none;
        transition: border-color .2s;
        min-width: 140px;
    }

        .rp-filter-input:focus {
            border-color: var(--rp-amber);
            box-shadow: 0 0 0 3px rgba(245,158,11,.1);
        }

    .rp-filter-clear {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        border: 1.5px solid var(--rp-border);
        background: #fff;
        color: var(--rp-muted);
        transition: all .2s;
    }

        .rp-filter-clear:hover {
            border-color: #ef4444;
            color: #ef4444;
        }

    .rp-filter-result {
        font-size: 13px;
        color: var(--rp-muted);
        align-self: center;
    }

    /* PANEL / GRID / CARD */
    .rp-panel {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .rp-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .rp-card {
        background: var(--rp-surface);
        border: 1.5px solid var(--rp-border);
        border-radius: var(--rp-radius);
        box-shadow: var(--rp-shadow);
        padding: 24px;
    }

    .rp-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .rp-card-title {
        font-family: var(--rp-ff);
        font-size: 16px;
        font-weight: 700;
        color: var(--rp-text);
        margin: 0;
        letter-spacing: .04em;
    }

    .rp-card-sub {
        font-size: 12px;
        color: var(--rp-muted);
    }

    .rp-sub-red {
        color: #ef4444;
        font-weight: 600;
    }

    .rp-chart-wrap {
        position: relative;
        width: 100%;
    }

        .rp-chart-wrap canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100% !important;
            height: 100% !important;
        }

    .rp-kpis-ventas {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 16px;
    }

    .rp-kpi-v {
        border-radius: 14px;
        padding: 22px 24px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        border: 1.5px solid transparent;
    }

    .rp-kpi-v-green {
        background: #ecfdf5;
        border-color: #a7f3d0;
    }

    .rp-kpi-v-blue {
        background: #eff6ff;
        border-color: #bfdbfe;
    }

    .rp-kpi-v-amber {
        background: #fffbeb;
        border-color: #fde68a;
    }

    .rp-kpi-v-lbl {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--rp-muted);
    }

    .rp-kpi-v-num {
        font-family: var(--rp-ff);
        font-size: 32px;
        font-weight: 800;
        color: var(--rp-text);
        line-height: 1.1;
    }

    .rp-kpi-v-sub {
        font-size: 12px;
        color: var(--rp-muted);
    }

    .rp-demo-badge {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        background: #fffbeb;
        border: 1.5px solid #fde68a;
        border-radius: 10px;
        font-size: 13px;
        color: #92400e;
    }

        .rp-demo-badge i {
            color: #f59e0b;
        }

    .rp-nodata {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        min-height: 120px;
        color: #94a3b8;
        font-size: 14px;
        gap: 8px;
    }

    @@media(max-width:1200px) {
        .rp-kpis {
            grid-template-columns: repeat(3,1fr);
        }
    }

    @@media(max-width:900px) {
        .rp-grid-2 {
            grid-template-columns: 1fr;
        }

        .rp-kpis {
            grid-template-columns: repeat(2,1fr);
        }

        .rp-kpis-ventas {
            grid-template-columns: 1fr;
        }
    }

    @@media(max-width:600px) {
        .rp-title {
            font-size: 30px;
        }

        .rp-kpis {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

@section Scripts {
    <script>
        (function(){

            // ── Datos del servidor ────────────────────────────────────────────
            const ORDENES_RAW        = @Html.Raw(Model.OrdenesJsonCompleto);
            const modelosData        = @Html.Raw(Model.MotoresPorModeloJson);
            const motDistData        = @Html.Raw(Model.MotoresDistribucionJson);
            const masServiciadosData = @Html.Raw(Model.MotoresPorDuenoJson);
            const stockData          = @Html.Raw(Model.ProductosStockJson);
            const bajosData          = @Html.Raw(Model.ProductosBajosJson);
            const CATEGORIAS_RAW     = @Html.Raw(Model.ProductosPorCategoriaJson);
            const ventasMesData      = @Html.Raw(Model.VentasPorMesJson);
            const metodoPagoData     = @Html.Raw(Model.PagosPorMetodoJson);
            const serviciosData      = @Html.Raw(Model.IngresosPorServicioJson);

            // ── Constantes de estilo ──────────────────────────────────────────
            const COLORES_ESTADO = {
                'Pendiente':'#f59e0b','En diagnóstico':'#3b82f6',
                'En reparación':'#8b5cf6','Completado':'#10b981','Cancelado':'#ef4444'
            };
            const PALETA = ['#3b82f6','#10b981','#f59e0b','#8b5cf6','#ef4444','#06b6d4','#f97316','#84cc16'];

            Chart.defaults.font  = { family:"'Barlow', sans-serif", size:12 };
            Chart.defaults.color = '#64748b';
            Chart.defaults.plugins.legend.labels.boxWidth = 14;
            Chart.defaults.plugins.legend.labels.padding  = 16;
            Chart.defaults.devicePixelRatio = window.devicePixelRatio || 2;

            const lbl = d => d.map(x => x.label);
            const val = d => d.map(x => x.value);

            function noData(id){
                const el = document.getElementById(id);
                if(!el) return;
                el.parentElement.innerHTML = '<div class="rp-nodata"><i class="bi bi-inbox"></i> Sin datos aún</div>';
            }

            const BASE_OPTS = { responsive:true, maintainAspectRatio:false };

            // ═════════════════════════════════════════════════════════════════
            // TAB ÓRDENES
            // ═════════════════════════════════════════════════════════════════
            let chartEstados, chartMeses, chartTecnicos;

            function buildOrdenesData(filtradas){
                const porEstado = {};
                filtradas.forEach(o => porEstado[o.estado] = (porEstado[o.estado]||0)+1);
                const estadosArr = Object.entries(porEstado).map(([k,v])=>({label:k,value:v}));

                const hoy = new Date();
                const meses = Array.from({length:6},(_,i)=>{
                    const d = new Date(hoy.getFullYear(), hoy.getMonth()-5+i, 1);
                    return { year:d.getFullYear(), month:d.getMonth(),
                             label:d.toLocaleString('es-CR',{month:'short',year:'numeric'}) };
                });
                const porMes = meses.map(m=>({
                    label: m.label,
                    value: filtradas.filter(o=>{
                        const d = new Date(o.creadoEn);
                        return d.getFullYear()===m.year && d.getMonth()===m.month;
                    }).length
                }));

                const porTec = {};
                filtradas.forEach(o=>{ if(o.tecnico) porTec[o.tecnico]=(porTec[o.tecnico]||0)+1; });
                const tecArr = Object.entries(porTec)
                    .map(([k,v])=>({label:k,value:v}))
                    .sort((a,b)=>b.value-a.value).slice(0,8);

                return { estadosArr, porMes, tecArr };
            }

            function renderOrdenes(filtradas){
                const { estadosArr, porMes, tecArr } = buildOrdenesData(filtradas);

                if(!chartEstados){
                    chartEstados = new Chart(document.getElementById('chartEstados'),{
                        type:'doughnut',
                        data:{ labels:lbl(estadosArr), datasets:[{
                            data:val(estadosArr),
                            backgroundColor:lbl(estadosArr).map(l=>COLORES_ESTADO[l]||'#94a3b8'),
                            borderWidth:2, borderColor:'#fff', hoverOffset:8
                        }]},
                        options:{ ...BASE_OPTS, cutout:'62%',
                            plugins:{ legend:{position:'right'},
                                tooltip:{callbacks:{label:c=>` ${c.label}: ${c.raw} órdenes`}} }}
                    });
                } else {
                    chartEstados.data.labels = lbl(estadosArr);
                    chartEstados.data.datasets[0].data = val(estadosArr);
                    chartEstados.data.datasets[0].backgroundColor = lbl(estadosArr).map(l=>COLORES_ESTADO[l]||'#94a3b8');
                    chartEstados.update();
                }

                if(!chartMeses){
                    chartMeses = new Chart(document.getElementById('chartMeses'),{
                        type:'line',
                        data:{ labels:lbl(porMes), datasets:[{ label:'Órdenes', data:val(porMes),
                            borderColor:'#3b82f6', backgroundColor:'rgba(59,130,246,.1)',
                            pointBackgroundColor:'#3b82f6', pointRadius:5, pointHoverRadius:7,
                            borderWidth:2.5, fill:true, tension:0.35 }]},
                        options:{ ...BASE_OPTS, plugins:{legend:{display:false}},
                            scales:{ y:{beginAtZero:true,ticks:{precision:0},grid:{color:'#f1f5f9'}},
                                     x:{grid:{display:false}} }}
                    });
                } else {
                    chartMeses.data.labels = lbl(porMes);
                    chartMeses.data.datasets[0].data = val(porMes);
                    chartMeses.update();
                }

                if(!chartTecnicos){
                    chartTecnicos = new Chart(document.getElementById('chartTecnicos'),{
                        type:'bar',
                        data:{ labels:lbl(tecArr), datasets:[{ label:'Órdenes asignadas', data:val(tecArr),
                            backgroundColor:PALETA, borderRadius:7, borderSkipped:false }]},
                        options:{ ...BASE_OPTS, plugins:{legend:{display:false}},
                            scales:{ y:{beginAtZero:true,ticks:{precision:0},grid:{color:'#f1f5f9'}},
                                     x:{grid:{display:false}} }}
                    });
                } else {
                    chartTecnicos.data.labels = lbl(tecArr);
                    chartTecnicos.data.datasets[0].data = val(tecArr);
                    chartTecnicos.data.datasets[0].backgroundColor = PALETA.slice(0,tecArr.length);
                    chartTecnicos.update();
                }

                const res = document.getElementById('ord-result');
                res.textContent = filtradas.length < ORDENES_RAW.length
                    ? `Mostrando ${filtradas.length} de ${ORDENES_RAW.length} órdenes` : '';
            }

            window.filtrarOrdenes = function(){
                const desde  = document.getElementById('ord-desde').value;
                const hasta  = document.getElementById('ord-hasta').value;
                const estado = document.getElementById('ord-estado').value;
                let f = ORDENES_RAW;
                if(desde)  f = f.filter(o => o.creadoEn >= desde);
                if(hasta)  f = f.filter(o => o.creadoEn <= hasta);
                if(estado) f = f.filter(o => o.estado === estado);
                renderOrdenes(f);
            };
            window.limpiarFiltrosOrdenes = function(){
                ['ord-desde','ord-hasta'].forEach(id => document.getElementById(id).value = '');
                document.getElementById('ord-estado').value = '';
                renderOrdenes(ORDENES_RAW);
            };

            // ═════════════════════════════════════════════════════════════════
            // TAB MOTORES
            // ═════════════════════════════════════════════════════════════════
            let chartModelos, chartMotDist, chartMasServ;

            if(motDistData.length){
                chartMotDist = new Chart(document.getElementById('chartMotDist'),{
                    type:'doughnut',
                    data:{ labels:lbl(motDistData), datasets:[{
                        data:val(motDistData),
                        backgroundColor:[...PALETA,'#94a3b8'],
                        borderWidth:2, borderColor:'#fff', hoverOffset:10
                    }]},
                    options:{ ...BASE_OPTS, cutout:'58%',
                        plugins:{ legend:{position:'right'},
                            tooltip:{callbacks:{label:c=>{
                                const total = c.dataset.data.reduce((a,b)=>a+b,0);
                                return ` ${c.label}: ${c.raw} (${Math.round(c.raw/total*100)}%)`;
                            }}} }}
                });
            } else noData('chartMotDist');

            if(masServiciadosData.length){
                chartMasServ = new Chart(document.getElementById('chartMasServiciados'),{
                    type:'bar',
                    data:{ labels:lbl(masServiciadosData), datasets:[{ label:'Órdenes',
                        data:val(masServiciadosData),
                        backgroundColor:PALETA, borderRadius:7, borderSkipped:false }]},
                    options:{ ...BASE_OPTS, plugins:{legend:{display:false}},
                        scales:{ y:{beginAtZero:true,ticks:{precision:0},grid:{color:'#f1f5f9'}},
                                 x:{grid:{display:false}} }}
                });
            } else noData('chartMasServiciados');

            function renderMotores(datos){
                if(!chartModelos){
                    chartModelos = new Chart(document.getElementById('chartModelos'),{
                        type:'bar',
                        data:{ labels:lbl(datos), datasets:[{ label:'Motores',
                            data:val(datos), backgroundColor:PALETA,
                            borderRadius:6, borderSkipped:false }]},
                        options:{ indexAxis:'y', ...BASE_OPTS, plugins:{legend:{display:false}},
                            scales:{ x:{beginAtZero:true,ticks:{precision:0},grid:{color:'#f1f5f9'}},
                                     y:{grid:{display:false}} }}
                    });
                } else {
                    chartModelos.data.labels = lbl(datos);
                    chartModelos.data.datasets[0].data = val(datos);
                    chartModelos.data.datasets[0].backgroundColor = PALETA.slice(0,datos.length);
                    chartModelos.update();
                }
            }

            window.filtrarMotores = function(){
                const buscar = document.getElementById('mot-buscar').value.toLowerCase().trim();
                const orden  = document.getElementById('mot-orden').value;

                const mapa = {};
                MOTORES_RAW.forEach(m => {
                    if(!buscar || m.modelo.toLowerCase().includes(buscar))
                        mapa[m.modelo] = (mapa[m.modelo]||0)+1;
                });
                let arr = Object.entries(mapa).map(([k,v])=>({label:k,value:v}));
                if(orden==='desc') arr.sort((a,b)=>b.value-a.value);
                else if(orden==='asc') arr.sort((a,b)=>a.value-b.value);
                else arr.sort((a,b)=>a.label.localeCompare(b.label));
                arr = arr.slice(0,8);

                renderMotores(arr);
                document.getElementById('mot-result').textContent =
                    buscar ? `${arr.length} modelo(s) encontrado(s)` : '';
                document.getElementById('mot-sub-bar').textContent =
                    buscar ? `Filtrado` : 'Top 8';
            };
            window.limpiarFiltrosMotores = function(){
                document.getElementById('mot-buscar').value = '';
                document.getElementById('mot-orden').value = 'desc';
                renderMotores(modelosData);
                document.getElementById('mot-result').textContent = '';
                document.getElementById('mot-sub-bar').textContent = 'Top 8';
            };

            if(modelosData.length){ renderMotores(modelosData); }
            else noData('chartModelos');

            // ═════════════════════════════════════════════════════════════════
            // TAB INVENTARIO
            // ═════════════════════════════════════════════════════════════════
            let chartStock, chartBajos;

            (function poblarCategorias(){
                const sel = document.getElementById('inv-cat');
                CATEGORIAS_RAW.forEach(c => {
                    const opt = document.createElement('option');
                    opt.value = c.categoria;
                    opt.textContent = c.categoria;
                    sel.appendChild(opt);
                });
            })();

            function renderInventario(catFiltro, modo){
                let stockFiltrado, bajosFiltrado;

                if(catFiltro){
                    const cat = CATEGORIAS_RAW.find(c => c.categoria === catFiltro);
                    if(cat){
                        const items = modo==='bajos'
                            ? cat.items.filter(p => p.value <= p.minimo)
                            : cat.items;
                        stockFiltrado = [{ label:cat.categoria, value:cat.totalStock }];
                        bajosFiltrado = items.slice(0,6);
                    } else { stockFiltrado=[]; bajosFiltrado=[]; }
                } else {
                    stockFiltrado = modo==='bajos'
                        ? CATEGORIAS_RAW.filter(c=>c.cantBajos>0).map(c=>({label:c.categoria,value:c.cantBajos}))
                        : stockData;
                    bajosFiltrado = bajosData;
                }

                const resEl = document.getElementById('inv-result');
                if(catFiltro || modo==='bajos'){
                    const total = stockFiltrado.reduce((s,x)=>s+x.value,0);
                    resEl.textContent = `${total} unidades en vista`;
                } else { resEl.textContent=''; }

                if(!chartStock){
                    chartStock = new Chart(document.getElementById('chartStock'),{
                        type:'bar',
                        data:{ labels:lbl(stockFiltrado), datasets:[{ label:'Unidades en stock',
                            data:val(stockFiltrado),
                            backgroundColor:PALETA.map(c=>c+'cc'), borderColor:PALETA,
                            borderWidth:1.5, borderRadius:7, borderSkipped:false }]},
                        options:{ ...BASE_OPTS, plugins:{legend:{display:false}},
                            scales:{ y:{beginAtZero:true,ticks:{precision:0},grid:{color:'#f1f5f9'}},
                                     x:{grid:{display:false},ticks:{maxRotation:35}} }}
                    });
                } else {
                    chartStock.data.labels = lbl(stockFiltrado);
                    chartStock.data.datasets[0].data = val(stockFiltrado);
                    chartStock.update();
                }

                const vs = val(bajosFiltrado);
                if(!chartBajos){
                    chartBajos = new Chart(document.getElementById('chartBajos'),{
                        type:'bar',
                        data:{ labels:lbl(bajosFiltrado), datasets:[{ label:'Stock actual', data:vs,
                            backgroundColor:vs.map(v=>v<=5?'#fecaca':v<=15?'#fef3c7':'#d1fae5'),
                            borderColor:vs.map(v=>v<=5?'#ef4444':v<=15?'#f59e0b':'#10b981'),
                            borderWidth:1.5, borderRadius:7, borderSkipped:false }]},
                        options:{ ...BASE_OPTS, plugins:{legend:{display:false},
                            tooltip:{callbacks:{label:c=>` Stock: ${c.raw} unidades`}}},
                            scales:{ y:{beginAtZero:true,ticks:{precision:0},grid:{color:'#f1f5f9'}},
                                     x:{grid:{display:false},ticks:{maxRotation:35}} }}
                    });
                } else {
                    chartBajos.data.labels = lbl(bajosFiltrado);
                    chartBajos.data.datasets[0].data = vs;
                    chartBajos.data.datasets[0].backgroundColor = vs.map(v=>v<=5?'#fecaca':v<=15?'#fef3c7':'#d1fae5');
                    chartBajos.data.datasets[0].borderColor = vs.map(v=>v<=5?'#ef4444':v<=15?'#f59e0b':'#10b981');
                    chartBajos.update();
                }
            }

            window.filtrarInventario = function(){
                const cat  = document.getElementById('inv-cat').value;
                const modo = document.getElementById('inv-modo').value;
                renderInventario(cat, modo);
            };
            window.limpiarFiltrosInventario = function(){
                document.getElementById('inv-cat').value  = '';
                document.getElementById('inv-modo').value = 'todos';
                renderInventario('','todos');
            };

            if(stockData.length) renderInventario('','todos');
            else { noData('chartStock'); noData('chartBajos'); }

            // ═════════════════════════════════════════════════════════════════
            // TAB VENTAS
            // ═════════════════════════════════════════════════════════════════
            let chartVentasMes;

            (function poblarMeses(){
                const desde = document.getElementById('ven-desde');
                const hasta = document.getElementById('ven-hasta');
                ventasMesData.forEach((m,i) => {
                    [desde,hasta].forEach(sel => {
                        const opt = document.createElement('option');
                        opt.value = i;
                        opt.textContent = m.label;
                        sel.appendChild(opt);
                    });
                });
                desde.value = 0;
                hasta.value = ventasMesData.length - 1;
            })();

            function renderVentas(datos){
                const total = datos.reduce((s,x)=>s+x.value,0);
                document.getElementById('ven-kpi-total').textContent =
                    '₡' + total.toLocaleString('es-CR');
                document.getElementById('ven-kpi-sub').textContent =
                    datos.length === 1 ? datos[0].label : `${datos[0].label} – ${datos[datos.length-1].label}`;

                if(!chartVentasMes){
                    chartVentasMes = new Chart(document.getElementById('chartVentasMes'),{
                        type:'line',
                        data:{ labels:lbl(datos), datasets:[{ label:'Ingresos (₡)', data:val(datos),
                            borderColor:'#10b981', backgroundColor:'rgba(16,185,129,.1)',
                            pointBackgroundColor:'#10b981', pointRadius:5, pointHoverRadius:7,
                            borderWidth:2.5, fill:true, tension:0.35 }]},
                        options:{ ...BASE_OPTS, plugins:{legend:{display:false}},
                            scales:{ y:{beginAtZero:true, grid:{color:'#f1f5f9'},
                                ticks:{callback:v=>'₡'+Number(v).toLocaleString('es-CR')}},
                                     x:{grid:{display:false}} }}
                    });
                } else {
                    chartVentasMes.data.labels = lbl(datos);
                    chartVentasMes.data.datasets[0].data = val(datos);
                    chartVentasMes.update();
                }
            }

            window.filtrarVentas = function(){
                const desde = parseInt(document.getElementById('ven-desde').value);
                const hasta = parseInt(document.getElementById('ven-hasta').value);
                const d = desde <= hasta
                    ? ventasMesData.slice(desde, hasta+1)
                    : ventasMesData.slice(hasta, desde+1);
                renderVentas(d);
                document.getElementById('ven-result').textContent =
                    d.length < ventasMesData.length ? `${d.length} mes(es) seleccionado(s)` : '';
            };
            window.limpiarFiltrosVentas = function(){
                document.getElementById('ven-desde').value = 0;
                document.getElementById('ven-hasta').value = ventasMesData.length - 1;
                renderVentas(ventasMesData);
                document.getElementById('ven-result').textContent = '';
            };

            renderVentas(ventasMesData);

            new Chart(document.getElementById('chartMetodoPago'),{
                type:'doughnut',
                data:{ labels:lbl(metodoPagoData), datasets:[{ data:val(metodoPagoData),
                    backgroundColor:['#3b82f6','#10b981','#8b5cf6','#f59e0b'],
                    borderWidth:2, borderColor:'#fff', hoverOffset:8 }]},
                options:{ ...BASE_OPTS, cutout:'62%',
                    plugins:{ legend:{position:'right'},
                        tooltip:{callbacks:{label:c=>` ${c.label}: ${c.raw}%`}} }}
            });

            new Chart(document.getElementById('chartServicios'),{
                type:'bar',
                data:{ labels:lbl(serviciosData), datasets:[{ label:'Ingresos (₡)', data:val(serviciosData),
                    backgroundColor:PALETA, borderRadius:7, borderSkipped:false }]},
                options:{ indexAxis:'y', ...BASE_OPTS, plugins:{legend:{display:false}},
                    scales:{ x:{beginAtZero:true, grid:{color:'#f1f5f9'},
                        ticks:{callback:v=>'₡'+Number(v).toLocaleString('es-CR')}},
                             y:{grid:{display:false}} }}
            });

            renderOrdenes(ORDENES_RAW);

        })();

        // ── Tabs ──────────────────────────────────────────────────────────────
        window.cambiarTab = function(tab, btn){
            document.querySelectorAll('.rp-panel').forEach(p => p.style.display='none');
            document.querySelectorAll('.rp-tab').forEach(b => b.classList.remove('active'));
            document.getElementById('panel-'+tab).style.display = 'flex';
            btn.classList.add('active');
        };

        // ── Modal y Export PDF ────────────────────────────────────────────────
        window.abrirModalPDF = function() {
            const modal = document.getElementById('pdfModal');
            modal.style.display = 'flex';

            const hoy = new Date();
            const hace30 = new Date();
            hace30.setDate(hoy.getDate() - 30);

            document.getElementById('pdfFechaDesde').value = hace30.toISOString().split('T')[0];
            document.getElementById('pdfFechaHasta').value = hoy.toISOString().split('T')[0];
        };

        window.cerrarModalPDF = function() {
            document.getElementById('pdfModal').style.display = 'none';
        };

        window.generarPDFConParametros = async function(btn) {
            const fechaDesde = document.getElementById('pdfFechaDesde').value;
            const fechaHasta = document.getElementById('pdfFechaHasta').value;
            const incluirKPIs = document.getElementById('pdfIncluirKPIs').checked;
            const incluirOrdenes = document.getElementById('pdfIncluirOrdenes').checked;
            const incluirMotores = document.getElementById('pdfIncluirMotores').checked;
            const incluirInventario = document.getElementById('pdfIncluirInventario').checked;
            const incluirVentas = document.getElementById('pdfIncluirVentas').checked;
            const orientacion = document.getElementById('pdfOrientacion').value;
            const tamano = document.getElementById('pdfTamano').value;
            const notas = document.getElementById('pdfNotas').value;

            const textoOriginal = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Generando...';
            btn.disabled = true;

            try {
                const pdfContent = document.createElement('div');
                pdfContent.style.padding = '20px';
                pdfContent.style.fontFamily = "'Barlow', sans-serif";
                pdfContent.style.backgroundColor = 'white';

                pdfContent.innerHTML = `
                    <div style="text-align: center; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 3px solid #f59e0b;">
                        <h1 style="font-family: 'Barlow Condensed', sans-serif; font-size: 28px; margin: 0; color: #1e293b;">📊 EP BOBINADO</h1>
                        <p style="font-size: 14px; color: #64748b; margin: 5px 0;">Reporte General del Taller</p>
                        <p style="font-size: 12px; color: #94a3b8; margin: 0;">Generado: ${new Date().toLocaleString('es-CR')}</p>
                        ${fechaDesde && fechaHasta ? `<p style="font-size: 12px; color: #f59e0b; margin-top: 10px;">📅 Período: ${new Date(fechaDesde).toLocaleDateString('es-CR')} - ${new Date(fechaHasta).toLocaleDateString('es-CR')}</p>` : ''}
                    </div>
                `;

                if (incluirKPIs) {
                    pdfContent.innerHTML += `
                        <div style="margin-bottom: 30px;">
                            <h2 style="font-size: 18px; color: #f59e0b; border-left: 4px solid #f59e0b; padding-left: 12px; margin-bottom: 16px;">📈 Indicadores Clave</h2>
                            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px;">
                                <div style="background: #f8fafc; padding: 15px; border-radius: 12px; text-align: center;"><div style="font-size: 28px; font-weight: 800; color: #1e293b;">@Model.TotalOrdenes</div><div style="font-size: 12px; color: #64748b;">Total órdenes</div></div>
                                <div style="background: #f8fafc; padding: 15px; border-radius: 12px; text-align: center;"><div style="font-size: 28px; font-weight: 800; color: #1e293b;">@Model.OrdenesActivas</div><div style="font-size: 12px; color: #64748b;">Órdenes activas</div></div>
                                <div style="background: #f8fafc; padding: 15px; border-radius: 12px; text-align: center;"><div style="font-size: 28px; font-weight: 800; color: #1e293b;">@Model.OrdenesCompletadas</div><div style="font-size: 12px; color: #64748b;">Completadas</div></div>
                                <div style="background: #f8fafc; padding: 15px; border-radius: 12px; text-align: center;"><div style="font-size: 28px; font-weight: 800; color: #1e293b;">@Model.TotalClientes</div><div style="font-size: 12px; color: #64748b;">Clientes</div></div>
                                <div style="background: #f8fafc; padding: 15px; border-radius: 12px; text-align: center;"><div style="font-size: 28px; font-weight: 800; color: #1e293b;">@Model.TotalMotores</div><div style="font-size: 12px; color: #64748b;">Motores</div></div>
                                <div style="background: #f8fafc; padding: 15px; border-radius: 12px; text-align: center;"><div style="font-size: 28px; font-weight: 800; color: #1e293b;">@Model.ProductosBajoStock</div><div style="font-size: 12px; color: #64748b;">Stock bajo</div></div>
                            </div>
                        </div>
                    `;
                }

                if (incluirOrdenes) {
                    const estados = ['Pendiente', 'En diagnóstico', 'En reparación', 'Completado', 'Cancelado'];
                    const conteos = {
                        'Pendiente': @Model.Ordenes.Count(o => o.Estado == "Pendiente"),
                        'En diagnóstico': @Model.Ordenes.Count(o => o.Estado == "En diagnóstico"),
                        'En reparación': @Model.Ordenes.Count(o => o.Estado == "En reparación"),
                        'Completado': @Model.Ordenes.Count(o => o.Estado == "Completado"),
                        'Cancelado': @Model.Ordenes.Count(o => o.Estado == "Cancelado")
                    };
                    const total = @Model.TotalOrdenes;

                    pdfContent.innerHTML += `
                        <div style="margin-bottom: 30px;">
                            <h2 style="font-size: 18px; color: #f59e0b; border-left: 4px solid #f59e0b; padding-left: 12px; margin-bottom: 16px;">📋 Distribución de Órdenes</h2>
                            <table style="width: 100%; border-collapse: collapse;">
                                <thead><tr style="background: #f1f5f9;"><th style="padding: 10px; text-align: left;">Estado</th><th style="padding: 10px; text-align: right;">Cantidad</th><th style="padding: 10px; text-align: right;">Porcentaje</th></tr></thead>
                                <tbody>
                                    ${estados.map(e => conteos[e] > 0 ? `<tr><td style="padding: 8px 10px; border-bottom: 1px solid #e2e8f0;">${e}</td><td style="padding: 8px 10px; text-align: right;">${conteos[e]}</td><td style="padding: 8px 10px; text-align: right;">${Math.round(conteos[e]/total*100)}%</td></tr>` : '').join('')}
                                </tbody>
                            </table>
                        </div>
                    `;
                }

                if (incluirMotores) {
                    const motores = @Html.Raw(Model.MotoresPorModeloJson);
                    pdfContent.innerHTML += `
                        <div style="margin-bottom: 30px;">
                            <h2 style="font-size: 18px; color: #f59e0b; border-left: 4px solid #f59e0b; padding-left: 12px; margin-bottom: 16px;">🔧 Motores por Modelo</h2>
                            <table style="width: 100%; border-collapse: collapse;">
                                <thead><tr style="background: #f1f5f9;"><th style="padding: 10px; text-align: left;">Modelo</th><th style="padding: 10px; text-align: right;">Cantidad</th></tr></thead>
                                <tbody>
                                    ${motores.map(m => `<tr><td style="padding: 8px 10px; border-bottom: 1px solid #e2e8f0;">${m.label}</td><td style="padding: 8px 10px; text-align: right;">${m.value}</td></tr>`).join('')}
                                </tbody>
                            </table>
                        </div>
                    `;
                }

                if (incluirInventario) {
                    const productosBajos = @Html.Raw(Model.ProductosBajosJson);
                    pdfContent.innerHTML += `
                        <div style="margin-bottom: 30px;">
                            <h2 style="font-size: 18px; color: #f59e0b; border-left: 4px solid #f59e0b; padding-left: 12px; margin-bottom: 16px;">📦 Resumen de Inventario</h2>
                            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; margin-bottom: 15px;">
                                <div style="background: #f8fafc; padding: 12px; border-radius: 10px;"><div style="font-size: 24px; font-weight: 800;">@Model.TotalProductos</div><div style="font-size: 12px;">Total Productos</div></div>
                                <div style="background: #fef3c7; padding: 12px; border-radius: 10px;"><div style="font-size: 24px; font-weight: 800; color: #d97706;">@Model.ProductosBajoStock</div><div style="font-size: 12px;">Productos con stock bajo</div></div>
                            </div>
                            <table style="width: 100%; border-collapse: collapse;">
                                <thead><tr style="background: #f1f5f9;"><th style="padding: 10px; text-align: left;">Producto</th><th style="padding: 10px; text-align: right;">Stock Actual</th></tr></thead>
                                <tbody>
                                    ${productosBajos.map(p => `<tr><td style="padding: 8px 10px; border-bottom: 1px solid #e2e8f0;">${p.label}</td><td style="padding: 8px 10px; text-align: right;">${p.value}</td></tr>`).join('')}
                                </tbody>
                            </table>
                        </div>
                    `;
                }

                if (incluirVentas) {
                    const ventasMes = @Html.Raw(Model.VentasPorMesJson);
                    const totalVentas = ventasMes.reduce((s,m)=>s+m.value,0);
                    pdfContent.innerHTML += `
                        <div style="margin-bottom: 30px;">
                            <h2 style="font-size: 18px; color: #f59e0b; border-left: 4px solid #f59e0b; padding-left: 12px; margin-bottom: 16px;">💰 Resumen de Ventas</h2>
                            <div style="background: #f0fdf4; padding: 20px; border-radius: 12px; text-align: center; margin-bottom: 15px;">
                                <div style="font-size: 32px; font-weight: 800; color: #059669;">₡${totalVentas.toLocaleString()}</div>
                                <div style="font-size: 13px;">Ingresos totales</div>
                            </div>
                            <table style="width: 100%; border-collapse: collapse;">
                                <thead><tr style="background: #f1f5f9;"><th style="padding: 10px; text-align: left;">Mes</th><th style="padding: 10px; text-align: right;">Ingresos</th></tr></thead>
                                <tbody>
                                    ${ventasMes.map(v => `<tr><td style="padding: 8px 10px; border-bottom: 1px solid #e2e8f0;">${v.label}</td><td style="padding: 8px 10px; text-align: right;">₡${v.value.toLocaleString()}</td></tr>`).join('')}
                                </tbody>
                            </table>
                        </div>
                    `;
                }

                if (notas) {
                    pdfContent.innerHTML += `
                        <div style="margin-top: 30px; padding: 15px; background: #fef9e3; border-left: 4px solid #f59e0b; border-radius: 8px;">
                            <p style="margin: 0; font-size: 12px; color: #78350f;"><strong>📝 Notas:</strong> ${notas}</p>
                        </div>
                    `;
                }

                pdfContent.innerHTML += `
                    <div style="margin-top: 40px; padding-top: 20px; text-align: center; border-top: 1px solid #e2e8f0; font-size: 10px; color: #94a3b8;">
                        Reporte generado automáticamente por EP Bobinado - Sistema de Gestión de Taller
                    </div>
                `;

                const opt = {
                    margin: [0.5, 0.5, 0.5, 0.5],
                    filename: `reporte_ep_bobinado_${new Date().toISOString().split('T')[0]}.pdf`,
                    image: { type: 'jpeg', quality: 0.98 },
                    html2canvas: { scale: 2, useCORS: true },
                    jsPDF: { unit: 'in', format: tamano, orientation: orientacion }
                };

                await html2pdf().set(opt).from(pdfContent).save();
                cerrarModalPDF();
            } catch (error) {
                console.error('Error al generar PDF:', error);
                alert('Error al generar el PDF. Por favor, intente de nuevo.');
            } finally {
                btn.innerHTML = textoOriginal;
                btn.disabled = false;
            }
        };
    </script>
}